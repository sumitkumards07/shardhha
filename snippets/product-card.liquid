
<div class="premium-product-card">
  <a href="{{ product.url | within: collection }}" class="premium-product-card__image-link">
    <div class="premium-product-card__image-wrapper">
      {% if product.featured_image != blank %}
        {{ product.featured_image | image_url: width: 600 | image_tag: class: 'premium-product-card__image', alt: product.title }}
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg premium-product-card__image' }}
      {% endif %}
      
      {% if product.compare_at_price > product.price %}
        <div class="premium-product-card__badge">Sale</div>
      {% endif %}
    </div>
  </a>
  
  <div class="premium-product-card__info">
    <a href="{{ product.url | within: collection }}" style="text-decoration: none;">
      <h3 class="premium-product-card__title">{{ product.title }}</h3>
    </a>
    
    <div class="premium-product-card__price">
      {% if product.compare_at_price > product.price %}
        <span>{{ product.price | money }}</span>
        <span class="premium-product-card__price-compare">{{ product.compare_at_price | money }}</span>
      {% else %}
        <span>{{ product.price | money }}</span>
      {% endif %}
    </div>

    <div class="premium-product-card__actions">
      <a href="{{ product.url | within: collection }}" class="premium-product-card__buy-btn" style="display:block; text-decoration:none;" {% unless product.available %}disabled{% endunless %}>
        {% if product.available %}
          Buy Now
        {% else %}
          Sold Out
        {% endif %}
      </a>
    </div>
  </div>
</div>
