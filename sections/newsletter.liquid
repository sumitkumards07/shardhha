<style>
.newsletter-section {
  padding: 3rem 0;
  background-color: var(--color-warm-ivory);
  text-align: center;
}
.newsletter-container {
  max-width: 600px;
  margin: 0 auto;
  padding: 0 1rem;
}
.newsletter-title {
  font-family: var(--font-heading);
  font-size: clamp(1.8rem, 4vw, 2.2rem);
  color: var(--color-dark-green);
  margin-bottom: 0.5rem;
}
.newsletter-desc {
  font-family: var(--font-body);
  font-size: 0.95rem;
  color: var(--color-primary-text);
  margin-bottom: 1.5rem;
}
.newsletter-form {
  display: flex;
  gap: 0;
  max-width: 500px;
  margin: 0 auto;
}
.newsletter-input {
  flex: 1;
  padding: 0.8rem 1.2rem;
  border: 1px solid var(--color-border);
  border-right: none;
  font-family: var(--font-body);
  font-size: 0.95rem;
  outline: none;
  background: #FAF9F6;
}
.newsletter-btn {
  background-color: var(--color-dark-green);
  color: #FAF9F6;
  border: none;
  padding: 0 1.5rem;
  font-family: var(--font-body);
  font-size: 0.9rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  cursor: pointer;
  transition: background-color 0.3s ease;
}
.newsletter-btn:hover {
  background-color: var(--color-muted-gold);
}
@media (max-width: 480px) {
  .newsletter-section {
    padding: 2rem 0;
  }
  .newsletter-form {
    flex-direction: column;
    gap: 0.8rem;
  }
  .newsletter-input {
    border-right: 1px solid var(--color-border);
    text-align: center;
  }
  .newsletter-btn {
    padding: 0.8rem 1rem;
    width: 100%;
  }
}
</style>

<section class="newsletter-section">
  <div class="newsletter-container">
    {% if section.settings.title != blank %}
      <h2 class="newsletter-title">{{ section.settings.title }}</h2>
    {% endif %}
    {% if section.settings.description != blank %}
      <p class="newsletter-desc">{{ section.settings.description }}</p>
    {% endif %}

    {% form 'customer', class: 'newsletter-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="email"
        name="contact[email]"
        class="newsletter-input"
        value="{% if customer %}{{ customer.email }}{% endif %}"
        placeholder="{{ section.settings.placeholder }}"
        aria-label="Email address"
        required>
      <button type="submit" class="newsletter-btn">
        {{ section.settings.button_text }}
      </button>
      
      {%- if form.errors -%}
        <div style="color: red; margin-top: 1rem;">{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</div>
      {%- endif -%}
      {%- if form.posted_successfully? -%}
        <div style="color: green; margin-top: 1rem;">Thanks for subscribing!</div>
      {%- endif -%}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Get Early Access to New Arrivals"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Be the first to know when new kurtis drop. No spam, ever."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input Placeholder",
      "default": "E-mail"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Subscribe"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
