<style>
.collection-page {
  padding: var(--section-spacing) 0;
  background-color: var(--color-warm-ivory);
}
.collection-header {
  text-align: center;
  margin-bottom: 3rem;
}
.collection-title {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 5vw, 3.5rem);
  color: var(--color-dark-green);
  margin-bottom: 1rem;
}
.collection-description {
  max-width: 600px;
  margin: 0 auto;
  color: var(--color-secondary-text);
  font-family: var(--font-body);
}
.collection-grid-container {
  display: flex;
  flex-wrap: wrap;
  gap: 2rem;
}
.collection-sidebar {
  flex: 0 0 250px;
}
.collection-grid {
  flex: 1;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 2rem;
}
.filter-group {
  margin-bottom: 1.5rem;
}
.filter-title {
  font-weight: 600;
  margin-bottom: 0.5rem;
  font-family: var(--font-body);
  color: var(--color-primary-text);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-size: 0.9rem;
}
.filter-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.filter-item {
  margin-bottom: 0.5rem;
}
.filter-label {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.9rem;
  color: var(--color-secondary-text);
  cursor: pointer;
}
@media (max-width: 768px) {
  .collection-grid-container {
    flex-direction: column;
  }
  .collection-sidebar {
    flex: 1 1 100%;
    margin-bottom: 2rem;
  }
}
</style>

<div class="collection-page">
  <div class="container">
    <header class="collection-header">
      <h1 class="collection-title">{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <div class="collection-description">{{ collection.description }}</div>
      {% endif %}
    </header>

    <div class="collection-grid-container">
      {% if section.settings.show_sidebar %}
        <aside class="collection-sidebar">
          <!-- Placeholder for Filters (In a real theme, use Shopify faceted filtering) -->
          <div class="filter-group">
            <div class="filter-title">Price</div>
            <ul class="filter-list">
              <li class="filter-item"><label class="filter-label"><input type="checkbox"> Under $50</label></li>
              <li class="filter-item"><label class="filter-label"><input type="checkbox"> $50 - $100</label></li>
              <li class="filter-item"><label class="filter-label"><input type="checkbox"> Over $100</label></li>
            </ul>
          </div>
          <div class="filter-group">
            <div class="filter-title">Availability</div>
            <ul class="filter-list">
              <li class="filter-item"><label class="filter-label"><input type="checkbox"> In Stock</label></li>
              <li class="filter-item"><label class="filter-label"><input type="checkbox"> Out of Stock</label></li>
            </ul>
          </div>
        </aside>
      {% endif %}

      <div class="collection-grid">
        {% paginate collection.products by section.settings.products_per_page %}
          {% for product in collection.products %}
            {% render 'product-card', product: product, collection: collection %}
          {% else %}
            <p>No products found in this collection.</p>
          {% endfor %}

          {% if paginate.pages > 1 %}
            <div class="pagination" style="grid-column: 1 / -1; text-align: center; margin-top: 2rem;">
              {{ paginate | default_pagination }}
            </div>
          {% endif %}
        {% endpaginate %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 24,
      "step": 4,
      "default": 12,
      "label": "Products per page"
    },
    {
      "type": "checkbox",
      "id": "show_sidebar",
      "default": true,
      "label": "Show filter sidebar"
    }
  ]
}
{% endschema %}
