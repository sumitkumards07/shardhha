<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
    tailwind.config = {
        darkMode: "class",
        theme: {
            extend: {
                "colors": {
                    "antique-cream": "#F5F0E8",
                    "deep-forest": "#0F2D24",
                    "soft-gold": "#a38f7b",
                    "subtle-grey": "#737973",
                    "surface-container-low": "#f6f3f2",
                    "outline-variant": "#c3c8c1"
                },
                "fontFamily": {
                    "headline-md": ["var(--font-heading)"],
                    "label-sm": ["var(--font-body)"],
                    "body-md": ["var(--font-body)"],
                    "display": ["var(--font-heading)"],
                    "headline-lg-mobile": ["var(--font-heading)"],
                    "body-lg": ["var(--font-body)"],
                    "headline-lg": ["var(--font-heading)"]
                }
            }
        }
    }
</script>
<style>
    .hide-scrollbar::-webkit-scrollbar { display: none; }
    .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    .bg-antique-cream { background-color: transparent !important; }
    .product-image-container { aspect-ratio: 3/4; overflow: hidden; }
</style>

<div class="bg-antique-cream text-deep-forest font-body-md pb-32">
  <div class="max-w-[1280px] mx-auto px-5 md:px-16">
    
    <!-- Filter Bar (Moved to top since Hero is gone) -->
    <section class="sticky top-0 z-40 bg-[#F5F0E8] py-4 border-b border-outline-variant/30 mb-8 mt-4">
      <div class="flex items-center justify-between overflow-x-auto hide-scrollbar gap-8">
        <div class="flex items-center gap-8">
          <div class="relative group cursor-pointer">
            <button class="flex items-center gap-2 text-[12px] uppercase tracking-widest text-deep-forest hover:text-soft-gold transition-colors font-semibold" style="font-family: var(--font-body);">
              Category <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </button>
          </div>
          <div class="relative group cursor-pointer">
            <button class="flex items-center gap-2 text-[12px] uppercase tracking-widest text-deep-forest hover:text-soft-gold transition-colors font-semibold" style="font-family: var(--font-body);">
              Price <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </button>
          </div>
          <div class="relative group cursor-pointer">
            <button class="flex items-center gap-2 text-[12px] uppercase tracking-widest text-deep-forest hover:text-soft-gold transition-colors font-semibold" style="font-family: var(--font-body);">
              Color <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </button>
          </div>
        </div>
        <div class="flex-shrink-0">
          <span class="text-[12px] uppercase tracking-widest text-subtle-grey font-semibold" style="font-family: var(--font-body);">
            {{ collection.all_products_count }} Styles
          </span>
        </div>
      </div>
    </section>

    <!-- Product Grid -->
    {% paginate collection.products by section.settings.products_per_page %}
      <section class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-y-10 gap-x-4 md:gap-x-6 mb-24">
        {% for product in collection.products %}
          <div class="group block flex flex-col h-full">
            <a href="{{ product.url }}" class="block mb-4">
              <div class="product-image-container bg-surface-container-low border border-outline-variant/30 relative rounded-2xl">
                {% if product.featured_image %}
                  {{ product.featured_image | image_url: width: 600 | image_tag: class: 'w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 rounded-2xl', alt: product.title }}
                {% else %}
                  <div class="w-full h-full flex items-center justify-center bg-gray-100 text-subtle-grey rounded-2xl">No Image</div>
                {% endif %}
                
                <!-- Quick Shop Hover Overlay (Optional enhancement) -->
                <div class="absolute inset-0 bg-deep-forest/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-2xl"></div>
              </div>
            </a>
            
            <div class="space-y-1 flex-grow text-center">
              <h3 class="text-[14px] md:text-[16px] text-deep-forest group-hover:text-soft-gold transition-colors font-semibold" style="font-family: var(--font-body);">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>
              <p class="text-[14px] font-semibold text-subtle-grey pt-1" style="font-family: var(--font-body);">{{ product.price | money }}</p>
            </div>
            
            <div class="mt-4 flex gap-2 w-full">
              {% form 'product', product, class: 'w-1/2' %}
                <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                <button type="submit" class="w-full py-2.5 bg-deep-forest text-antique-cream text-[10px] md:text-[11px] uppercase tracking-wider font-semibold rounded-full hover:bg-opacity-90 transition-all">Add to Cart</button>
              {% endform %}
              <a href="{{ product.url }}" class="w-1/2 py-2.5 border border-deep-forest text-deep-forest text-[10px] md:text-[11px] uppercase tracking-wider font-semibold rounded-full hover:bg-surface-container-low transition-all text-center flex items-center justify-center">Buy Now</a>
            </div>
          </div>
        {% else %}
          <!-- Demo Products if collection is empty -->
          {% for i in (1..8) %}
            <div class="group block flex flex-col h-full">
              <a href="#" class="block mb-4">
                <div class="product-image-container bg-surface-container-low border border-outline-variant/30 relative rounded-2xl">
                  <img src="https://images.unsplash.com/photo-1596455607563-ad6193f76b17?q=80&w=600&auto=format&fit=crop" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 rounded-2xl" alt="Demo Product">
                </div>
              </a>
              
              <div class="space-y-1 flex-grow text-center">
                <h3 class="text-[14px] md:text-[16px] text-deep-forest group-hover:text-soft-gold transition-colors font-semibold" style="font-family: var(--font-body);">
                  <a href="#">Handcrafted Kurti Set</a>
                </h3>
                <p class="text-[14px] font-semibold text-subtle-grey pt-1" style="font-family: var(--font-body);">₹4,250</p>
              </div>
              
              <div class="mt-4 flex gap-2 w-full">
                <button type="button" class="w-1/2 py-2.5 bg-deep-forest text-antique-cream text-[10px] md:text-[11px] uppercase tracking-wider font-semibold rounded-full hover:bg-opacity-90 transition-all">Add to Cart</button>
                <button type="button" class="w-1/2 py-2.5 border border-deep-forest text-deep-forest text-[10px] md:text-[11px] uppercase tracking-wider font-semibold rounded-full hover:bg-surface-container-low transition-all">Buy Now</button>
              </div>
            </div>
          {% endfor %}
        {% endfor %}
      </section>

      {% if paginate.pages > 1 %}
        <div class="flex justify-center mt-12 gap-4" style="font-family: var(--font-body);">
          {{ paginate | default_pagination: next: 'Next', previous: 'Previous' }}
        </div>
      {% endif %}
    {% endpaginate %}

  </div>
</div>

{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 24,
      "step": 4,
      "label": "Products per page",
      "default": 16
    }
  ]
}
{% endschema %}
