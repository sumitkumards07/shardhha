<style>
.search-page {
  padding: var(--section-spacing) 0;
  min-height: 50vh;
}
.search-page__header {
  text-align: center;
  margin-bottom: 3rem;
}
.search-page__title {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 4vw, 3rem);
  color: var(--color-dark-green);
  margin-bottom: 1.5rem;
}
.search-page__form {
  max-width: 600px;
  margin: 0 auto 2rem;
  display: flex;
  gap: 0;
  border: 1px solid var(--color-border);
  border-radius: 50px;
  overflow: hidden;
  background: #FAF9F6;
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}
.search-page__form:focus-within {
  border-color: var(--color-dark-green);
  box-shadow: 0 0 0 3px rgba(15,45,36,0.08);
}
.search-page__input {
  flex: 1;
  padding: 1rem 1.5rem;
  border: none !important;
  font-family: var(--font-body);
  font-size: 1rem;
  outline: none;
  background: transparent !important;
  border-radius: 0 !important;
}
.search-page__submit {
  background-color: var(--color-dark-green);
  color: #FAF9F6;
  border: none;
  padding: 0 2rem;
  font-family: var(--font-body);
  font-size: 0.85rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  cursor: pointer;
  transition: background-color 0.3s ease;
  border-radius: 50px;
  margin: 4px;
}
.search-page__submit:hover {
  background-color: var(--color-muted-gold);
}
.search-page__count {
  text-align: center;
  font-family: var(--font-body);
  color: var(--color-secondary-text);
  font-size: 0.95rem;
  margin-bottom: 2rem;
}
.search-results-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}
@media (min-width: 768px) {
  .search-results-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
}
@media (min-width: 1024px) {
  .search-results-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}
.search-result-card {
  background: #FAF9F6;
  border: 1px solid var(--color-border);
  border-radius: 20px;
  overflow: hidden;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.search-result-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.06);
}
.search-result-card__image {
  aspect-ratio: 3/4;
  overflow: hidden;
}
.search-result-card__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}
.search-result-card:hover .search-result-card__image img {
  transform: scale(1.05);
}
.search-result-card__info {
  padding: 1.2rem;
  text-align: center;
}
.search-result-card__title {
  font-family: var(--font-body);
  font-size: 0.95rem;
  font-weight: 500;
  color: var(--color-primary-text);
  text-decoration: none;
  display: block;
  margin-bottom: 0.5rem;
  line-height: 1.3;
}
.search-result-card__price {
  font-family: var(--font-body);
  font-weight: 600;
  color: var(--color-dark-green);
  font-size: 0.95rem;
}
.search-page__empty {
  text-align: center;
  padding: 4rem 0;
}
.search-page__empty-icon {
  width: 64px;
  height: 64px;
  margin: 0 auto 1.5rem;
  color: var(--color-secondary-text);
  opacity: 0.4;
}
.search-page__empty-text {
  font-family: var(--font-body);
  color: var(--color-secondary-text);
  font-size: 1.1rem;
  margin-bottom: 1.5rem;
}
</style>

<div class="search-page">
  <div class="container">
    <div class="search-page__header">
      <h1 class="search-page__title">
        {% if search.performed %}
          Search Results
        {% else %}
          Search
        {% endif %}
      </h1>
      
      <form action="{{ routes.search_url }}" method="get" class="search-page__form">
        <input type="search" name="q" value="{{ search.terms | escape }}" class="search-page__input" placeholder="Search for kurtis, sarees, collections..." autocomplete="off">
        <button type="submit" class="search-page__submit">Search</button>
      </form>

      {% if search.performed %}
        <p class="search-page__count">
          {{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %} for "{{ search.terms }}"
        </p>
      {% endif %}
    </div>

    {% if search.performed %}
      {% if search.results_count > 0 %}
        <div class="search-results-grid">
          {% for item in search.results %}
            <a href="{{ item.url }}" class="search-result-card">
              <div class="search-result-card__image">
                {% if item.featured_image %}
                  {{ item.featured_image | image_url: width: 600 | image_tag: alt: item.title }}
                {% elsif item.image %}
                  {{ item.image | image_url: width: 600 | image_tag: alt: item.title }}
                {% else %}
                  <div style="width:100%;height:100%;background:#f0eded;display:flex;align-items:center;justify-content:center;color:var(--color-secondary-text);font-size:0.85rem;">No Image</div>
                {% endif %}
              </div>
              <div class="search-result-card__info">
                <span class="search-result-card__title">{{ item.title }}</span>
                {% if item.price %}
                  <span class="search-result-card__price">{{ item.price | money }}</span>
                {% endif %}
              </div>
            </a>
          {% endfor %}
        </div>
      {% else %}
        <div class="search-page__empty">
          <svg class="search-page__empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          <p class="search-page__empty-text">No results found for "{{ search.terms }}"</p>
          <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary">Browse All Products</a>
        </div>
      {% endif %}

      {% if search.results_count > 20 %}
        <div style="text-align: center; margin-top: 3rem;">
          {{ paginate | default_pagination }}
        </div>
      {% endif %}
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Search Results",
  "settings": []
}
{% endschema %}
