<style>
.faq-section {
  padding: var(--section-spacing) 0;
  background-color: var(--color-warm-ivory);
}
.faq-container {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 4rem;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 2rem;
}
.faq-header {
  position: sticky;
  top: 100px;
  align-self: start;
}
.faq-title {
  font-family: var(--font-heading);
  font-size: clamp(2.5rem, 4vw, 3.5rem);
  color: var(--color-dark-green);
  line-height: 1.1;
  margin: 0;
}
.faq-accordion {
  display: flex;
  flex-direction: column;
}
.faq-item {
  border-bottom: 1px solid var(--color-border);
}
.faq-item:first-child {
  border-top: 1px solid var(--color-border);
}
.faq-question {
  width: 100%;
  text-align: left;
  background: none;
  border: none;
  padding: 1.5rem 0;
  font-family: var(--font-body);
  font-size: 1.15rem;
  font-weight: 500;
  color: var(--color-primary-text);
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.faq-icon-wrapper {
  position: relative;
  width: 24px;
  height: 24px;
  flex-shrink: 0;
  margin-left: 1rem;
}
.faq-icon {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  transition: transform 200ms ease, opacity 200ms ease;
  color: var(--color-dark-green);
}
.faq-icon-plus {
  opacity: 1;
  transform: rotate(0) scale(1);
}
.faq-icon-minus {
  opacity: 0;
  transform: rotate(-90deg) scale(0);
}
.faq-item.active .faq-icon-plus {
  opacity: 0;
  transform: rotate(90deg) scale(0);
}
.faq-item.active .faq-icon-minus {
  opacity: 1;
  transform: rotate(0) scale(1);
}
.faq-answer {
  max-height: 0;
  opacity: 0;
  overflow: hidden;
  transition: max-height 400ms ease, opacity 400ms ease;
}
.faq-answer-inner {
  padding-bottom: 1.5rem;
  color: var(--color-secondary-text);
  line-height: 1.6;
}
.faq-item.active .faq-answer {
  max-height: 500px;
  opacity: 1;
}

@media (max-width: 768px) {
  .faq-container {
    grid-template-columns: 1fr;
    gap: 2rem;
    padding: 0 1.5rem;
  }
  .faq-header {
    position: relative;
    top: 0;
  }
  .faq-question {
    font-size: 1.05rem;
  }
}
</style>

<section class="faq-section">
  <div class="faq-container">
    {% if section.settings.title != blank %}
      <div class="faq-header">
        <h2 class="faq-title">{{ section.settings.title }}</h2>
      </div>
    {% endif %}

    <div class="faq-accordion">
      {% for block in section.blocks %}
        <div class="faq-item" {{ block.shopify_attributes }}>
          <button class="faq-question" aria-expanded="false">
            {{ block.settings.question }}
            <div class="faq-icon-wrapper">
              <svg class="faq-icon faq-icon-plus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
              <svg class="faq-icon faq-icon-minus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/></svg>
            </div>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              {{ block.settings.answer }}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const faqQuestions = document.querySelectorAll('.faq-question');
    faqQuestions.forEach(question => {
      question.addEventListener('click', () => {
        const item = question.parentNode;
        const isActive = item.classList.contains('active');
        
        // Close all other items to ensure only one is open
        document.querySelectorAll('.faq-item').forEach(otherItem => {
          otherItem.classList.remove('active');
          otherItem.querySelector('.faq-question').setAttribute('aria-expanded', 'false');
        });

        // Open the clicked item if it was not active
        if (!isActive) {
          item.classList.add('active');
          question.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "FAQ Accordion",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long does shipping take?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Standard shipping typically takes 5-7 business days. Express shipping is available at checkout."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Accordion",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "How should I care for my silk sarees and embroidered kurtis?", "answer": "We highly recommend dry cleaning for all silk sarees, heavy fabrics, and embroidered pieces to maintain their intricate detailing and shine. For daily wear cotton kurtis, a gentle hand wash in cold water is ideal." } },
        { "type": "faq_item", "settings": { "question": "Do you provide custom stitching for blouses?", "answer": "All our sarees come with an attached unstitched blouse piece. At this time, we do not offer custom tailoring or stitching services, allowing you to design the blouse exactly to your local tailor's fit." } },
        { "type": "faq_item", "settings": { "question": "What is your return and exchange policy?", "answer": "We accept returns and exchanges within 7 days of delivery. Please ensure the garments are unworn, unwashed, and have all original tags intact. Fall-picot or stitched sarees cannot be returned." } },
        { "type": "faq_item", "settings": { "question": "How long will it take to receive my order?", "answer": "Standard domestic orders are processed within 2-3 business days and typically arrive in 5-7 business days. International shipping timelines vary between 10-14 business days depending on customs." } },
        { "type": "faq_item", "settings": { "question": "Can I track my order once it has shipped?", "answer": "Absolutely! As soon as your order is dispatched, you will receive a shipping confirmation email containing a tracking link so you can monitor your package right to your doorstep." } }
      ]
    }
  ]
}
{% endschema %}
