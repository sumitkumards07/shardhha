<style>
/* ── Header Base ── */
.header {
  padding: 1.25rem 0;
  border-bottom: 1px solid var(--color-border);
  background-color: var(--color-warm-ivory);
  position: sticky;
  top: 0;
  z-index: 100;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}
.header__inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.header__logo {
  font-family: var(--font-heading);
  font-size: 1.8rem;
  color: var(--color-dark-green);
  text-decoration: none;
  font-weight: 600;
  letter-spacing: 0.02em;
}
.header__nav {
  display: flex;
  gap: 2rem;
}
.header__nav-link {
  color: var(--color-primary-text);
  text-decoration: none;
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  font-weight: 500;
  transition: color 0.3s ease;
  position: relative;
  padding-bottom: 4px;
}
.header__nav-link::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0;
  height: 1.5px;
  background-color: var(--color-dark-green);
  transition: width 0.3s ease;
}
.header__nav-link:hover { color: var(--color-dark-green); }
.header__nav-link:hover::after { width: 100%; }
.header__icons {
  display: flex;
  gap: 1.25rem;
  align-items: center;
}
.header__icon-btn,
.header__icon-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  transition: background-color 0.3s ease, color 0.3s ease;
  color: var(--color-primary-text);
  background: none;
  border: none;
  cursor: pointer;
  text-decoration: none;
}
.header__icon-btn:hover,
.header__icon-link:hover {
  background-color: rgba(15, 45, 36, 0.08);
  color: var(--color-dark-green);
}
.header__icon {
  width: 22px;
  height: 22px;
}
.header__hamburger {
  display: none;
  background: none;
  border: none;
  cursor: pointer;
  padding: 8px;
  border-radius: 12px;
  transition: background-color 0.3s ease;
}
.header__hamburger:hover { background-color: rgba(15, 45, 36, 0.08); }
.header__hamburger svg { width: 24px; height: 24px; }

/* ── Search Overlay ── */
.search-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.4);
  backdrop-filter: blur(4px);
  z-index: 200;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}
.search-overlay.active {
  opacity: 1;
  visibility: visible;
}
.search-overlay__panel {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  background: var(--color-warm-ivory);
  padding: 1.5rem 2rem;
  transform: translateY(-100%);
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 8px 32px rgba(0,0,0,0.1);
}
.search-overlay.active .search-overlay__panel {
  transform: translateY(0);
}
.search-overlay__inner {
  max-width: 700px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: 1rem;
}
.search-overlay__input {
  flex: 1;
  padding: 1rem 1.5rem;
  border: 1px solid var(--color-border);
  border-radius: 50px;
  font-family: var(--font-body);
  font-size: 1rem;
  background: #FAF9F6;
  outline: none;
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}
.search-overlay__input:focus {
  border-color: var(--color-dark-green);
  box-shadow: 0 0 0 3px rgba(15,45,36,0.08);
}
.search-overlay__submit {
  background: var(--color-dark-green);
  color: #FAF9F6;
  border: none;
  padding: 0.9rem 2rem;
  border-radius: 50px;
  font-family: var(--font-body);
  font-size: 0.85rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  cursor: pointer;
  transition: background-color 0.3s ease;
  white-space: nowrap;
}
.search-overlay__submit:hover { background-color: var(--color-muted-gold); }
.search-overlay__close {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--color-primary-text);
  padding: 8px;
  border-radius: 50%;
  transition: background-color 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}
.search-overlay__close:hover { background-color: rgba(0,0,0,0.06); }
.search-overlay__close svg { width: 24px; height: 24px; }

/* ── Mobile Menu Drawer ── */
.mobile-drawer-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.4);
  backdrop-filter: blur(4px);
  z-index: 200;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}
.mobile-drawer-overlay.active {
  opacity: 1;
  visibility: visible;
}
.mobile-drawer {
  position: fixed;
  top: 0;
  left: 0;
  width: 85%;
  max-width: 360px;
  height: 100%;
  background: var(--color-warm-ivory);
  z-index: 210;
  transform: translateX(-100%);
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  overflow-y: auto;
  display: flex;
  flex-direction: column;
}
.mobile-drawer.active {
  transform: translateX(0);
}
.mobile-drawer__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem;
  border-bottom: 1px solid var(--color-border);
}
.mobile-drawer__logo {
  font-family: var(--font-heading);
  font-size: 1.4rem;
  color: var(--color-dark-green);
  font-weight: 600;
  text-decoration: none;
}
.mobile-drawer__close {
  background: none;
  border: none;
  cursor: pointer;
  padding: 8px;
  border-radius: 50%;
  color: var(--color-primary-text);
  transition: background-color 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}
.mobile-drawer__close:hover { background-color: rgba(0,0,0,0.06); }
.mobile-drawer__close svg { width: 24px; height: 24px; }
.mobile-drawer__nav {
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0;
  flex: 1;
}
.mobile-drawer__link {
  display: block;
  padding: 1rem 0;
  font-family: var(--font-body);
  font-size: 1.1rem;
  font-weight: 500;
  color: var(--color-primary-text);
  text-decoration: none;
  border-bottom: 1px solid var(--color-border);
  transition: color 0.3s ease, padding-left 0.3s ease;
}
.mobile-drawer__link:hover {
  color: var(--color-dark-green);
  padding-left: 8px;
}
.mobile-drawer__footer {
  padding: 1.5rem;
  border-top: 1px solid var(--color-border);
  margin-top: auto;
}
.mobile-drawer__search {
  display: flex;
  gap: 0.5rem;
}
.mobile-drawer__search-input {
  flex: 1;
  padding: 0.75rem 1.25rem;
  border: 1px solid var(--color-border);
  border-radius: 50px;
  font-family: var(--font-body);
  font-size: 0.9rem;
  background: #FAF9F6;
  outline: none;
}
.mobile-drawer__search-input:focus {
  border-color: var(--color-dark-green);
}
.mobile-drawer__search-btn {
  background: var(--color-dark-green);
  color: #FAF9F6;
  border: none;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  flex-shrink: 0;
}
.mobile-drawer__search-btn svg { width: 18px; height: 18px; }

@media (max-width: 768px) {
  .header__nav { display: none; }
  .header__hamburger { display: block; }
  .header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }
  .header__logo { font-size: 1.4rem; text-align: center; }
  .header__icons { justify-content: flex-end; gap: 0.5rem; }
  .header__icon-btn, .header__icon-link { width: 36px; height: 36px; }
}
</style>

<!-- ═══════════ Header ═══════════ -->
<header class="header">
  <div class="container header__inner">
    <button class="header__hamburger" id="mobileMenuOpen" aria-label="Open menu">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
    
    <a href="{{ routes.root_url }}" class="header__logo">
      {{ shop.name }}
    </a>
    
    <nav class="header__nav">
      {% for link in linklists.main-menu.links %}
        <a href="{{ link.url }}" class="header__nav-link">{{ link.title }}</a>
      {% endfor %}
      {% if linklists.main-menu.links.size == 0 %}
        <a href="#" class="header__nav-link">New In</a>
        <a href="#" class="header__nav-link">Kurtis</a>
        <a href="#" class="header__nav-link">Sarees</a>
        <a href="#" class="header__nav-link">Festive</a>
      {% endif %}
    </nav>
    
    <div class="header__icons">
      <button type="button" class="header__icon-btn" id="searchOpen" aria-label="Open search">
        <svg class="header__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      </button>
      <a href="{{ routes.cart_url }}" class="header__icon-link" aria-label="Cart">
        <svg class="header__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0"/></svg>
      </a>
    </div>
  </div>
</header>

<!-- ═══════════ Search Overlay ═══════════ -->
<div class="search-overlay" id="searchOverlay">
  <div class="search-overlay__panel">
    <form action="{{ routes.search_url }}" method="get" class="search-overlay__inner">
      <input type="search" name="q" class="search-overlay__input" placeholder="Search for kurtis, sarees, collections..." autocomplete="off" autofocus>
      <button type="submit" class="search-overlay__submit">Search</button>
      <button type="button" class="search-overlay__close" id="searchClose" aria-label="Close search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </form>
  </div>
</div>

<!-- ═══════════ Mobile Menu Drawer ═══════════ -->
<div class="mobile-drawer-overlay" id="mobileOverlay"></div>
<div class="mobile-drawer" id="mobileDrawer">
  <div class="mobile-drawer__header">
    <a href="{{ routes.root_url }}" class="mobile-drawer__logo">{{ shop.name }}</a>
    <button class="mobile-drawer__close" id="mobileMenuClose" aria-label="Close menu">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>
  <nav class="mobile-drawer__nav">
    {% for link in linklists.main-menu.links %}
      <a href="{{ link.url }}" class="mobile-drawer__link">{{ link.title }}</a>
    {% endfor %}
    {% if linklists.main-menu.links.size == 0 %}
      <a href="#" class="mobile-drawer__link">New In</a>
      <a href="/collections/all" class="mobile-drawer__link">Shop All</a>
      <a href="#" class="mobile-drawer__link">Kurtis</a>
      <a href="#" class="mobile-drawer__link">Sarees</a>
      <a href="#" class="mobile-drawer__link">Festive</a>
      <a href="{{ routes.cart_url }}" class="mobile-drawer__link">Cart</a>
    {% endif %}
  </nav>
  <div class="mobile-drawer__footer">
    <form action="{{ routes.search_url }}" method="get" class="mobile-drawer__search">
      <input type="search" name="q" class="mobile-drawer__search-input" placeholder="Search...">
      <button type="submit" class="mobile-drawer__search-btn" aria-label="Search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      </button>
    </form>
  </div>
</div>

<!-- ═══════════ JavaScript ═══════════ -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // ── Search Overlay ──
  const searchOpen = document.getElementById('searchOpen');
  const searchOverlay = document.getElementById('searchOverlay');
  const searchClose = document.getElementById('searchClose');

  if (searchOpen && searchOverlay) {
    searchOpen.addEventListener('click', function() {
      searchOverlay.classList.add('active');
      setTimeout(function() {
        searchOverlay.querySelector('input')?.focus();
      }, 350);
    });
  }
  if (searchClose) {
    searchClose.addEventListener('click', function() {
      searchOverlay.classList.remove('active');
    });
  }
  if (searchOverlay) {
    searchOverlay.addEventListener('click', function(e) {
      if (e.target === searchOverlay) {
        searchOverlay.classList.remove('active');
      }
    });
  }

  // ── Mobile Drawer ──
  const mobileOpen = document.getElementById('mobileMenuOpen');
  const mobileClose = document.getElementById('mobileMenuClose');
  const mobileDrawer = document.getElementById('mobileDrawer');
  const mobileOverlay = document.getElementById('mobileOverlay');

  function openDrawer() {
    mobileDrawer.classList.add('active');
    mobileOverlay.classList.add('active');
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    mobileDrawer.classList.remove('active');
    mobileOverlay.classList.remove('active');
    document.body.style.overflow = '';
  }

  if (mobileOpen) mobileOpen.addEventListener('click', openDrawer);
  if (mobileClose) mobileClose.addEventListener('click', closeDrawer);
  if (mobileOverlay) mobileOverlay.addEventListener('click', closeDrawer);

  // Close on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      closeDrawer();
      if (searchOverlay) searchOverlay.classList.remove('active');
    }
  });
});
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Primary Menu"
    },
    {
      "type": "link_list",
      "id": "secondary_menu",
      "label": "Secondary Menu"
    }
  ]
}
{% endschema %}
