<style>
  /* ── Product Page Layout ── */
  .pdp { padding: 1.5rem 0 4rem; overflow-x: hidden; }
  .pdp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .pdp-grid > * {
    min-width: 0;
  }
  @media (min-width: 768px) {
    .pdp-grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
    .pdp { padding: 1.5rem 0 4rem; }
  }
  @media (min-width: 1024px) {
    .pdp-grid {
      grid-template-columns: 55% 45%;
      gap: 4rem;
    }
  }

  /* ── Image Gallery (Desktop: Stacked Editorial) ── */
  .pdp-gallery {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .pdp-gallery__item {
    width: 100%;
    overflow: hidden;
    border-radius: 0px;
    background: #f5f2f0;
    cursor: zoom-in;
    position: relative;
  }
  .pdp-gallery__item img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .pdp-gallery__item:hover img {
    transform: scale(1.04);
  }

  /* ── Image Gallery (Mobile: full-width swiper like Myntra) ── */
  @media (max-width: 767px) {
    .pdp { padding: 0 0 5rem; overflow-x: hidden; }
    .pdp .container { padding: 0; max-width: 100%; }
    .pdp-grid { gap: 0; }
    
    .pdp-gallery-wrapper {
      width: 100%;
      margin: 0;
    }
    .pdp-gallery {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
      gap: 0.5rem;
      padding: 0 1rem;
      width: 100%;
    }
    .pdp-gallery::-webkit-scrollbar { display: none; }
    .pdp-gallery__item {
      flex: 0 0 100%;
      width: 100%;
      min-width: 100%;
      scroll-snap-align: center;
      height: 60vh;
      border-radius: 0px;
      background: #f5f2f0;
      overflow: hidden;
    }
    .pdp-gallery__item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .pdp-info {
      padding: 1rem 1.25rem 0;
    }
  }

  /* ── Gallery Dots (mobile only) ── */
  .pdp-gallery-dots {
    display: none;
  }
  @media (max-width: 767px) {
    .pdp-gallery-dots {
      display: flex;
      justify-content: center;
      gap: 6px;
      padding: 0.75rem 0 0;
    }
    .pdp-gallery-dots__dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--color-border);
      transition: all 0.3s ease;
    }
    .pdp-gallery-dots__dot.active {
      background: var(--color-dark-green);
      width: 20px;
      border-radius: 10px;
    }
  }

  /* ── Product Info Sidebar ── */
  .pdp-info { position: relative; }
  .pdp-info__sticky {
    position: sticky;
    top: 100px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    scrollbar-width: none;
  }
  .pdp-info__sticky::-webkit-scrollbar { display: none; }
  @media (max-width: 767px) {
    .pdp-info__sticky {
      position: relative;
      top: 0;
      max-height: none;
      overflow-y: visible;
    }
  }

  /* Breadcrumbs */
  .pdp-breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-family: var(--font-body);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-secondary-text);
    margin-bottom: 1.5rem;
  }
  .pdp-breadcrumbs a {
    color: var(--color-secondary-text);
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .pdp-breadcrumbs a:hover { color: var(--color-dark-green); }
  .pdp-breadcrumbs svg { width: 12px; height: 12px; opacity: 0.5; }
  @media (max-width: 767px) {
    .pdp-breadcrumbs { display: none; }
  }

  /* Title */
  .pdp-title {
    font-family: var(--font-heading);
    font-size: clamp(1.4rem, 5vw, 2.2rem);
    color: var(--color-dark-green);
    line-height: 1.2;
    margin-bottom: 0.25rem;
    word-wrap: break-word;
  }
  .pdp-subtitle {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: var(--color-secondary-text);
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }
  @media (max-width: 767px) {
    .pdp-title { font-size: 1.25rem; margin-bottom: 0.2rem; }
    .pdp-subtitle { font-size: 0.8rem; margin-bottom: 0.5rem; }
  }

  /* Price */
  .pdp-price {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }
  .pdp-price__current {
    font-family: var(--font-body);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-dark-green);
  }
  .pdp-price__compare {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-secondary-text);
    text-decoration: line-through;
  }
  .pdp-price__badge {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: #e8f5e9;
    color: #2e7d32;
    padding: 0.25rem 0.75rem;
    border-radius: 0px;
  }
  @media (max-width: 767px) {
    .pdp-price { margin-bottom: 1rem; padding-bottom: 1rem; }
    .pdp-price__current { font-size: 1.3rem; }
    .pdp-price__compare { font-size: 0.9rem; }
  }

  /* Variants */
  .pdp-option { margin-bottom: 1.25rem; }
  .pdp-option__label {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary-text);
    margin-bottom: 0.6rem;
    display: block;
  }
  .pdp-option__values {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .pdp-option__value { cursor: pointer; }
  .pdp-option__value input { display: none; }
  .pdp-option__value span {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    height: 44px;
    padding: 0 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 0px;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--color-primary-text);
    transition: all 0.2s ease;
  }
  .pdp-option__value input:checked + span {
    background: var(--color-dark-green);
    border-color: var(--color-dark-green);
    color: #FAF9F6;
  }
  .pdp-option__value:hover span {
    border-color: var(--color-dark-green);
  }
  @media (max-width: 767px) {
    .pdp-option { margin-bottom: 1rem; }
    .pdp-option__label { font-size: 0.75rem; margin-bottom: 0.5rem; }
    .pdp-option__value span {
      min-width: 40px;
      height: 40px;
      padding: 0 0.75rem;
      font-size: 0.8rem;
      border-radius: 0px;
    }
  }

  /* Quantity */
  .pdp-quantity {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .pdp-quantity__label {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .pdp-quantity__controls {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-border);
    border-radius: 0px;
    overflow: hidden;
  }
  .pdp-quantity__btn {
    background: none;
    border: none;
    padding: 0.6rem 1rem;
    cursor: pointer;
    font-size: 1.1rem;
    color: var(--color-primary-text);
    transition: background 0.2s ease;
    line-height: 1;
  }
  .pdp-quantity__btn:hover { background: rgba(0,0,0,0.04); }
  .pdp-quantity__input {
    width: 40px;
    text-align: center;
    border: none !important;
    border-left: 1px solid var(--color-border) !important;
    border-right: 1px solid var(--color-border) !important;
    border-radius: 0 !important;
    font-family: var(--font-body);
    font-size: 0.9rem;
    padding: 0.5rem 0;
    background: transparent !important;
  }

  /* ── Inline Action Buttons (hidden on mobile, replaced by sticky bar) ── */
  .pdp-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  @media (max-width: 767px) {
    .pdp-actions { display: none; }
  }
  .pdp-btn-primary {
    width: 100%;
    background: var(--color-dark-green);
    color: #FAF9F6;
    border: none;
    padding: 1.1rem;
    border-radius: 0px;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    line-height: 1;
  }
  .pdp-btn-primary:hover { background: var(--color-muted-gold); }
  .pdp-btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
  .pdp-btn-primary svg { width: 20px; height: 20px; }
  .pdp-btn-secondary {
    width: 100%;
    background: transparent;
    color: var(--color-primary-text);
    border: 1px solid var(--color-dark-green);
    padding: 1.1rem;
    border-radius: 0px;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    text-decoration: none;
    line-height: 1;
  }
  .pdp-btn-secondary:hover {
    border-color: var(--color-dark-green);
    color: var(--color-dark-green);
  }
  .pdp-btn-secondary svg { width: 18px; height: 18px; }

  /* ── Sticky Bottom Bar (Myntra-style, mobile only) ── */
  .pdp-sticky-bar {
    display: none;
  }
  @media (max-width: 767px) {
    .pdp-sticky-bar {
      display: flex;
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      z-index: 150;
      background: #FAF9F6;
      border-top: 1px solid var(--color-border);
      padding: 0.75rem 1rem;
      gap: 0.75rem;
      box-shadow: 0 -4px 16px rgba(0,0,0,0.06);
    }
    .pdp-sticky-bar__btn {
      flex: 1;
      padding: 0.85rem;
      border-radius: 0px;
      font-family: var(--font-body);
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      transition: all 0.3s ease;
      border: none;
      line-height: 1;
    }
    .pdp-sticky-bar__btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    .pdp-sticky-bar__btn svg { width: 18px; height: 18px; }
    .pdp-sticky-bar__btn--cart {
      background: transparent;
      border: 1px solid var(--color-dark-green);
      color: var(--color-dark-green);
    }
    .pdp-sticky-bar__btn--buy {
      background: var(--color-dark-green);
      color: #FAF9F6;
    }
    .pdp { padding-bottom: 5rem; } /* space for sticky bar */
  }

  /* USP Row */
  .pdp-usp {
    display: flex;
    gap: 1.5rem;
    padding: 1.25rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .pdp-usp__item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: var(--color-secondary-text);
  }
  .pdp-usp__item svg { width: 18px; height: 18px; color: var(--color-dark-green); flex-shrink: 0; }
  @media (max-width: 767px) {
    .pdp-usp {
      display: flex;
      justify-content: space-between;
      gap: 0.5rem;
      text-align: center;
      padding: 1rem 0;
    }
    .pdp-usp__item {
      flex: 1;
      flex-direction: column;
      gap: 0.4rem;
      font-size: 0.7rem;
      line-height: 1.2;
    }
  }

  /* Accordion Tabs */
  .pdp-tabs { margin-top: 0.5rem; }
  .pdp-tab {
    border-bottom: 1px solid var(--color-border);
  }
  .pdp-tab__trigger {
    width: 100%;
    background: none;
    border: none;
    padding: 1rem 0;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary-text);
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: color 0.3s ease;
  }
  .pdp-tab__trigger:hover { color: var(--color-dark-green); }
  .pdp-tab__trigger svg {
    width: 18px;
    height: 18px;
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }
  .pdp-tab.active .pdp-tab__trigger svg {
    transform: rotate(180deg);
  }
  .pdp-tab__content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }
  .pdp-tab.active .pdp-tab__content {
    max-height: 500px;
  }
  .pdp-tab__body {
    padding-bottom: 1.25rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-secondary-text);
  }
  @media (max-width: 767px) {
    .pdp-tab__trigger { font-size: 0.78rem; padding: 0.85rem 0; }
    .pdp-tab__body { font-size: 0.85rem; }
  }
</style>

{% assign current_product = product %}

<div class="pdp">
  <div class="container">
    <div class="pdp-grid">

      <!-- ═══ LEFT: Image Gallery ═══ -->
      <div class="pdp-gallery-wrapper">
        <div class="pdp-gallery" id="pdpGallery-{{ section.id }}">
          {% if current_product and current_product.images.size > 0 %}
            {% for image in current_product.images limit: 5 %}
              <div class="pdp-gallery__item">
                {% if forloop.first %}
                  {{ image | image_url: width: 1000 | image_tag: alt: current_product.title, preload: true }}
                {% else %}
                  {{ image | image_url: width: 1000 | image_tag: alt: current_product.title, loading: 'lazy' }}
                {% endif %}
              </div>
            {% endfor %}
          {% else %}
            <div class="pdp-gallery__item">
              <img src="https://images.unsplash.com/photo-1610030469983-98e550d6193c?q=80&w=1000&auto=format&fit=crop" alt="Product" fetchpriority="high">
            </div>
            <div class="pdp-gallery__item">
              <img src="https://images.unsplash.com/photo-1583391733958-d25e07fac66e?q=80&w=800&auto=format&fit=crop" alt="Product" loading="lazy">
            </div>
            <div class="pdp-gallery__item">
              <img src="https://images.unsplash.com/photo-1596455607563-ad6193f76b17?q=80&w=800&auto=format&fit=crop" alt="Product" loading="lazy">
            </div>
          {% endif %}
        </div>
        <!-- Dots (mobile only) -->
        <div class="pdp-gallery-dots" id="pdpDots-{{ section.id }}"></div>
      </div>

      <!-- ═══ RIGHT: Product Info ═══ -->
      <div class="pdp-info">
        <div class="pdp-info__sticky">

          <!-- Breadcrumbs (desktop only) -->
          <nav class="pdp-breadcrumbs">
            <a href="{{ routes.root_url }}">Home</a>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
            {% if current_product.collections.size > 0 %}
              <a href="{{ current_product.collections.first.url }}">{{ current_product.collections.first.title }}</a>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
            {% endif %}
            <span style="color: var(--color-primary-text);">{{ current_product.title | default: 'Product' }}</span>
          </nav>

          <!-- Title & Subtitle -->
          {% for block in section.blocks %}
            {% case block.type %}

              {% when 'title' %}
                <h1 class="pdp-title" {{ block.shopify_attributes }}>{{ current_product.title | default: 'Ruhani Hand-Embroidered Kurti' }}</h1>
                {% if current_product.vendor %}
                  <p class="pdp-subtitle">by {{ current_product.vendor }}</p>
                {% endif %}

              {% when 'price' %}
                <div class="pdp-price" {{ block.shopify_attributes }}>
                  <span class="pdp-price__current">
                    {% if current_product %}{{ current_product.price | money }}{% else %}₹2,499{% endif %}
                  </span>
                  {% if current_product and current_product.compare_at_price > current_product.price %}
                    <span class="pdp-price__compare">{{ current_product.compare_at_price | money }}</span>
                    {% assign discount = current_product.compare_at_price | minus: current_product.price | times: 100 | divided_by: current_product.compare_at_price %}
                    <span class="pdp-price__badge">{{ discount }}% OFF</span>
                  {% endif %}
                  {% if current_product == nil %}
                    <span class="pdp-price__compare">₹3,999</span>
                    <span class="pdp-price__badge">37% OFF</span>
                  {% endif %}
                </div>

              {% when 'description' %}
                {% if current_product and current_product.description != blank %}
                  <p class="pdp-subtitle" style="margin-bottom: 1.25rem;" {{ block.shopify_attributes }}>
                    {{ current_product.description | strip_html | truncatewords: 30 }}
                  </p>
                {% else %}
                  <p class="pdp-subtitle" style="margin-bottom: 1.25rem;">
                    A testament to slow fashion. Delicate cream hand-embroidery on premium organic cotton, crafted by master artisans.
                  </p>
                {% endif %}

              {% when 'form' %}
                <div {{ block.shopify_attributes }}>
                  {% form 'product', current_product, id: 'pdp-form' %}
                    <input type="hidden" name="id" value="{% if current_product %}{{ current_product.selected_or_first_available_variant.id }}{% endif %}">

                    <!-- Variants -->
                    {% if current_product %}
                      {% unless current_product.has_only_default_variant %}
                        {% for option in current_product.options_with_values %}
                          <div class="pdp-option">
                            <span class="pdp-option__label">{{ option.name }}</span>
                            <div class="pdp-option__values">
                              {% for value in option.values %}
                                <label class="pdp-option__value">
                                  <input type="radio" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" {% if option.selected_value == value %}checked{% endif %}>
                                  <span>{{ value }}</span>
                                </label>
                              {% endfor %}
                            </div>
                          </div>
                        {% endfor %}
                      {% endunless %}
                    {% else %}
                      <!-- Demo Sizes -->
                      <div class="pdp-option">
                        <span class="pdp-option__label">Size</span>
                        <div class="pdp-option__values">
                          <label class="pdp-option__value"><input type="radio" name="size" checked><span>S</span></label>
                          <label class="pdp-option__value"><input type="radio" name="size"><span>M</span></label>
                          <label class="pdp-option__value"><input type="radio" name="size"><span>L</span></label>
                          <label class="pdp-option__value"><input type="radio" name="size"><span>XL</span></label>
                        </div>
                      </div>
                    {% endif %}

                    <!-- Quantity -->
                    <div class="pdp-quantity">
                      <span class="pdp-quantity__label">Quantity</span>
                      <div class="pdp-quantity__controls">
                        <button type="button" class="pdp-quantity__btn" onclick="this.nextElementSibling.stepDown()">−</button>
                        <input type="number" name="quantity" value="1" min="1" class="pdp-quantity__input">
                        <button type="button" class="pdp-quantity__btn" onclick="this.previousElementSibling.stepUp()">+</button>
                      </div>
                    </div>

                    <!-- Inline Action Buttons (desktop only, hidden on mobile) -->
                    <div class="pdp-actions">
                      <button type="submit" name="add" class="pdp-btn-primary" {% if current_product and current_product.available == false %}disabled{% endif %}>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
                        <span id="pdp-btn-text">{% if current_product and current_product.available == false %}Sold Out{% else %}Add to Cart{% endif %}</span>
                      </button>
                      <button type="button" class="pdp-btn-secondary" onclick="var f=this.closest('form');if(f){var ex=f.querySelector('input[name=return_to]');if(ex)ex.remove();var h=document.createElement('input');h.type='hidden';h.name='return_to';h.value='/checkout';f.appendChild(h);f.submit();}">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        Buy Now
                      </button>
                    </div>
                  {% endform %}
                  {% if current_product %}
                    <script id="ProductJson-{{ section.id }}" type="application/json">
                      {{ current_product.variants | json }}
                    </script>
                  {% endif %}
                </div>

              {% when 'accordion' %}
                <!-- USP Row -->
                <div class="pdp-usp">
                  <div class="pdp-usp__item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
                    Free Delivery
                  </div>
                  <div class="pdp-usp__item">
