<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
    tailwind.config = {
        darkMode: "class",
        theme: {
            extend: {
                "colors": {
                    "antique-cream": "#F5F0E8",
                    "deep-forest": "#0F2D24",
                    "soft-gold": "#a38f7b",
                    "subtle-grey": "#737973",
                    "surface-container-low": "#f6f3f2",
                    "outline-variant": "#c3c8c1"
                },
                "fontFamily": {
                    "headline-md": ["var(--font-heading)"],
                    "label-sm": ["var(--font-body)"],
                    "body-md": ["var(--font-body)"],
                    "display": ["var(--font-heading)"],
                    "headline-lg-mobile": ["var(--font-heading)"],
                    "body-lg": ["var(--font-body)"],
                    "headline-lg": ["var(--font-heading)"]
                }
            }
        }
    }
</script>
<style>
    .hide-scrollbar::-webkit-scrollbar { display: none; }
    .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    
    .accordion-content {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease-out;
    }
    .accordion-active .accordion-content {
        max-height: 500px;
    }
    .accordion-active .accordion-icon {
        transform: rotate(180deg);
    }
    
    /* Override tailwind background so it uses our theme texture */
    .bg-antique-cream {
      background-color: transparent !important;
    }
</style>

{% assign current_product = product | default: null %}

<div class="bg-antique-cream text-deep-forest font-body-md" style="padding-top: 4rem; padding-bottom: 4rem;">
  <div class="max-w-[1280px] mx-auto px-5 md:px-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
      
      <!-- Product Gallery -->
      <section class="space-y-6">
        <div class="aspect-[3/4] overflow-hidden bg-surface-container-low group">
          {% if current_product and current_product.featured_image %}
            {{ current_product.featured_image | image_url: width: 1000 | image_tag: class: 'w-full h-full object-cover transition-transform duration-700 group-hover:scale-105', id: 'MainImage' }}
          {% else %}
            <img src="https://images.unsplash.com/photo-1610030469983-98e550d6193c?q=80&w=1000&auto=format&fit=crop" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" alt="Demo Product">
          {% endif %}
        </div>
        
        <!-- Thumbnail Scroll -->
        <div class="flex gap-4 overflow-x-auto hide-scrollbar pb-2">
          {% if current_product and current_product.images.size > 1 %}
            {% for image in current_product.images %}
              <div class="flex-shrink-0 w-24 aspect-[3/4] border border-transparent hover:border-outline-variant transition-colors cursor-pointer">
                {{ image | image_url: width: 200 | image_tag: class: 'w-full h-full object-cover' }}
              </div>
            {% endfor %}
          {% else %}
             <div class="flex-shrink-0 w-24 aspect-[3/4] border border-deep-forest p-0.5 cursor-pointer">
              <img src="https://images.unsplash.com/photo-1610030469983-98e550d6193c?q=80&w=200&auto=format&fit=crop" class="w-full h-full object-cover">
             </div>
             <div class="flex-shrink-0 w-24 aspect-[3/4] border border-transparent hover:border-outline-variant transition-colors cursor-pointer">
              <img src="https://images.unsplash.com/photo-1583391733958-d25e07fac66e?q=80&w=200&auto=format&fit=crop" class="w-full h-full object-cover">
             </div>
          {% endif %}
        </div>
      </section>

      <!-- Product Info -->
      <section class="flex flex-col h-full sticky top-10">
        
        {% for block in section.blocks %}
          {% case block.type %}
            
            {% when 'title' %}
              <div class="mb-2" {{ block.shopify_attributes }}>
                <span class="text-[12px] font-semibold uppercase tracking-widest text-soft-gold" style="font-family: var(--font-body);">{{ block.settings.subtitle | default: 'Essential Solids' }}</span>
              </div>
              <h1 class="font-headline-lg text-[32px] md:text-[40px] text-deep-forest mb-4 leading-tight" style="font-family: var(--font-heading);">
                {{ current_product.title | default: 'Ruhani Boat Neck Kurti' }}
              </h1>
              
            {% when 'price' %}
              <div class="flex items-center gap-4 mb-6" {{ block.shopify_attributes }}>
                <p class="text-[24px] font-medium text-deep-forest" style="font-family: var(--font-body);">
                  {% if current_product %}
                    {{ current_product.price | money }}
                  {% else %}
                    ₹899.00
                  {% endif %}
                </p>
                {% if current_product and current_product.compare_at_price > current_product.price %}
                  <p class="text-[18px] text-subtle-grey line-through">{{ current_product.compare_at_price | money }}</p>
                {% endif %}
              </div>

            {% when 'description' %}
              <div class="text-[16px] text-subtle-grey leading-relaxed mb-10 max-w-lg" style="font-family: var(--font-body);" {{ block.shopify_attributes }}>
                {% if current_product %}
                  {{ current_product.description }}
                {% else %}
                  Embrace the elegance of summer with our Ruhani Boat Neck Kurti. Crafted from premium breathable cotton, this piece features subtle weaving textures and artisanal details designed for the modern woman who appreciates slow fashion.
                {% endif %}
              </div>
              
            {% when 'form' %}
              <div class="space-y-10 mb-12" {{ block.shopify_attributes }}>
                {% form 'product', current_product, class: 'w-full' %}
                  <input type="hidden" name="id" value="{% if current_product %}{{ current_product.selected_or_first_available_variant.id }}{% endif %}">
                  
                  <!-- Size / Variants -->
                  {% if current_product %}
                    {% unless current_product.has_only_default_variant %}
                      {% for option in current_product.options_with_values %}
                        <div class="mb-6">
                          <div class="flex justify-between items-center mb-4">
                            <span class="text-[12px] font-semibold uppercase tracking-wider" style="font-family: var(--font-body);">Select {{ option.name }}</span>
                          </div>
                          <div class="flex gap-3 flex-wrap">
                            {% for value in option.values %}
                              <label class="cursor-pointer">
                                <input type="radio" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" class="hidden peer" {% if option.selected_value == value %}checked{% endif %}>
                                <div class="w-12 h-12 flex items-center justify-center border border-outline-variant text-deep-forest text-[12px] font-semibold peer-checked:bg-deep-forest peer-checked:text-antique-cream transition-all hover:border-deep-forest" style="font-family: var(--font-body);">
                                  {{ value }}
                                </div>
                              </label>
                            {% endfor %}
                          </div>
                        </div>
                      {% endfor %}
                    {% endunless %}
                  {% else %}
                    <!-- Demo Sizes -->
                    <div class="mb-6">
                      <div class="flex justify-between items-center mb-4">
                        <span class="text-[12px] font-semibold uppercase tracking-wider" style="font-family: var(--font-body);">Select Size</span>
                      </div>
                      <div class="flex gap-3">
                        <div class="w-12 h-12 flex items-center justify-center border border-deep-forest bg-deep-forest text-antique-cream text-[12px] font-semibold cursor-pointer" style="font-family: var(--font-body);">S</div>
                        <div class="w-12 h-12 flex items-center justify-center border border-outline-variant text-deep-forest text-[12px] font-semibold cursor-pointer hover:border-deep-forest" style="font-family: var(--font-body);">M</div>
                        <div class="w-12 h-12 flex items-center justify-center border border-outline-variant text-deep-forest text-[12px] font-semibold cursor-pointer hover:border-deep-forest" style="font-family: var(--font-body);">L</div>
                      </div>
                    </div>
                  {% endif %}

                  <!-- Quantity -->
                  <div class="mb-8">
                    <span class="text-[12px] font-semibold uppercase tracking-wider block mb-4" style="font-family: var(--font-body);">Quantity</span>
                    <div class="inline-flex items-center border border-outline-variant h-12">
                      <button type="button" class="px-4 py-2 hover:bg-surface-container-low transition-colors" onclick="this.nextElementSibling.stepDown()">
                        <span style="font-size: 1.2rem;">-</span>
                      </button>
                      <input type="number" name="quantity" value="1" min="1" class="w-10 text-center font-body-md bg-transparent border-none focus:ring-0 p-0" style="font-family: var(--font-body);">
                      <button type="button" class="px-4 py-2 hover:bg-surface-container-low transition-colors" onclick="this.previousElementSibling.stepUp()">
                        <span style="font-size: 1.2rem;">+</span>
                      </button>
                    </div>
                  </div>

                  <!-- CTA Button -->
                  <button type="submit" name="add" class="w-full bg-deep-forest text-antique-cream py-4 px-8 text-[14px] font-semibold uppercase tracking-widest hover:bg-opacity-90 transition-all flex items-center justify-center gap-3 disabled:opacity-50 disabled:cursor-not-allowed" style="font-family: var(--font-body);" {% if current_product and current_product.available == false %}disabled{% endif %}>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="mb-0.5"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
                    {% if current_product and current_product.available == false %}
                      SOLD OUT
                    {% else %}
                      ADD TO CART
                    {% endif %}
                  </button>
                {% endform %}
              </div>
              
            {% when 'accordion' %}
              <div class="border-t border-outline-variant" {{ block.shopify_attributes }}>
                
                <div class="accordion-item border-b border-outline-variant py-4">
                  <button type="button" class="flex justify-between items-center w-full group" onclick="this.parentElement.classList.toggle('accordion-active')">
                    <span class="text-[14px] font-semibold uppercase tracking-wider text-deep-forest" style="font-family: var(--font-body);">{{ block.settings.tab_1_title | default: 'Fabric Care' }}</span>
                    <svg class="accordion-icon transition-transform duration-300 text-deep-forest" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                  </button>
                  <div class="accordion-content">
                    <div class="pt-4 pb-2 text-[16px] text-subtle-grey leading-relaxed" style="font-family: var(--font-body);">
                      {{ block.settings.tab_1_content | default: '100% Pure Woven Cotton. Hand wash separately in cold water using mild detergent. Dry in shade to maintain color longevity.' }}
                    </div>
                  </div>
                </div>

                <div class="accordion-item border-b border-outline-variant py-4">
                  <button type="button" class="flex justify-between items-center w-full group" onclick="this.parentElement.classList.toggle('accordion-active')">
                    <span class="text-[14px] font-semibold uppercase tracking-wider text-deep-forest" style="font-family: var(--font-body);">{{ block.settings.tab_2_title | default: 'Shipping Info' }}</span>
                    <svg class="accordion-icon transition-transform duration-300 text-deep-forest" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                  </button>
                  <div class="accordion-content">
                    <div class="pt-4 pb-2 text-[16px] text-subtle-grey leading-relaxed" style="font-family: var(--font-body);">
                      {{ block.settings.tab_2_content | default: 'Free shipping on orders above ₹1299. Standard delivery in 5-7 business days.' }}
                    </div>
                  </div>
                </div>

                <div class="accordion-item border-b border-outline-variant py-4">
                  <button type="button" class="flex justify-between items-center w-full group" onclick="this.parentElement.classList.toggle('accordion-active')">
                    <span class="text-[14px] font-semibold uppercase tracking-wider text-deep-forest" style="font-family: var(--font-body);">{{ block.settings.tab_3_title | default: 'Returns' }}</span>
                    <svg class="accordion-icon transition-transform duration-300 text-deep-forest" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                  </button>
                  <div class="accordion-content">
                    <div class="pt-4 pb-2 text-[16px] text-subtle-grey leading-relaxed" style="font-family: var(--font-body);">
                      {{ block.settings.tab_3_content | default: '7-day hassle-free returns and exchanges.' }}
                    </div>
                  </div>
                </div>

              </div>

          {% endcase %}
        {% endfor %}
        
      </section>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product Information",
  "settings": [],
  "blocks": [
    {
      "type": "title",
      "name": "Title",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle / Category Label",
          "default": "Essential Solids"
        }
      ]
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1
    },
    {
      "type": "description",
      "name": "Description",
      "limit": 1
    },
    {
      "type": "form",
      "name": "Variant Picker & Buy",
      "limit": 1
    },
    {
      "type": "accordion",
      "name": "Information Accordions",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "tab_1_title",
          "label": "Tab 1 Title",
          "default": "Fabric Care"
        },
        {
          "type": "textarea",
          "id": "tab_1_content",
          "label": "Tab 1 Content",
          "default": "100% Pure Woven Cotton. Hand wash separately in cold water using mild detergent."
        },
        {
          "type": "text",
          "id": "tab_2_title",
          "label": "Tab 2 Title",
          "default": "Shipping Info"
        },
        {
          "type": "textarea",
          "id": "tab_2_content",
          "label": "Tab 2 Content",
          "default": "Free shipping on orders above ₹1299."
        },
        {
          "type": "text",
          "id": "tab_3_title",
          "label": "Tab 3 Title",
          "default": "Returns"
        },
        {
          "type": "textarea",
          "id": "tab_3_content",
          "label": "Tab 3 Content",
          "default": "7-day hassle-free returns and exchanges."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Information",
      "blocks": [
        { "type": "title" },
        { "type": "price" },
        { "type": "description" },
        { "type": "form" },
        { "type": "accordion" }
      ]
    }
  ]
}
{% endschema %}
