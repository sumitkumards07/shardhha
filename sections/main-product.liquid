<!-- ═══ Sticky Bottom Bar (Myntra-style, mobile only) ═══ -->
<div class="pdp-sticky-bar">
  <button type="button" class="pdp-sticky-bar__btn pdp-sticky-bar__btn--cart" id="sticky-btn-cart" onclick="var f=document.getElementById('pdp-form'); if(f){f.requestSubmit ? f.requestSubmit() : f.submit();}" {% if current_product and current_product.available == false %}disabled{% endif %}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
    <span id="sticky-btn-cart-text">{% if current_product and current_product.available == false %}Sold Out{% else %}Add to Cart{% endif %}</span>
  </button>
  <button type="button" class="pdp-sticky-bar__btn pdp-sticky-bar__btn--buy" id="sticky-btn-buy" onclick="var f=document.getElementById('pdp-form');if(f){var ex=f.querySelector('input[name=return_to]');if(ex)ex.remove();var h=document.createElement('input');h.type='hidden';h.name='return_to';h.value='/checkout';f.appendChild(h);f.submit();}" {% if current_product and current_product.available == false %}disabled{% endif %}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    Buy Now
  </button>
</div>

<!-- ═══ Gallery Dots JS ═══ -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  var gallery = document.getElementById('pdpGallery-{{ section.id }}');
  var dotsContainer = document.getElementById('pdpDots-{{ section.id }}');
  if (!gallery || !dotsContainer) return;

  var items = gallery.querySelectorAll('.pdp-gallery__item');
  if (items.length <= 1) return;

  // Create dots
  items.forEach(function(_, i) {
    var dot = document.createElement('div');
    dot.className = 'pdp-gallery-dots__dot' + (i === 0 ? ' active' : '');
    dotsContainer.appendChild(dot);
  });

  var dots = dotsContainer.querySelectorAll('.pdp-gallery-dots__dot');

  // Update dots on scroll
  var scrollTimeout;
  gallery.addEventListener('scroll', function() {
    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(function() {
      var scrollLeft = gallery.scrollLeft;
      var itemWidth = items[0].offsetWidth;
      var activeIndex = Math.round(scrollLeft / itemWidth);
      dots.forEach(function(d, i) {
        d.classList.toggle('active', i === activeIndex);
      });
    }, 50);
  });
});

// Variant Selector Logic
document.addEventListener('DOMContentLoaded', function() {
  var form = document.getElementById('pdp-form');
  var jsonEl = document.getElementById('ProductJson-{{ section.id }}');
  if (!form || !jsonEl) return;
  
  try {
    var variants = JSON.parse(jsonEl.innerHTML);
    var radios = form.querySelectorAll('input[type="radio"]');
    var idInput = form.querySelector('input[name="id"]');
    var priceEl = document.querySelector('.pdp-price__current');
    var btnText = document.getElementById('pdp-btn-text');
    var btn = form.querySelector('button[name="add"]');
    var stickyCartBtn = document.getElementById('sticky-btn-cart');
    var stickyCartBtnText = document.getElementById('sticky-btn-cart-text');
    var stickyBuyBtn = document.getElementById('sticky-btn-buy');
    
    var productOptions = {{ current_product.options | json }} || [];
    
    radios.forEach(function(radio) {
      radio.addEventListener('change', function() {
        // Find selected options
        var selectedOptions = {};
        form.querySelectorAll('input[type="radio"]:checked').forEach(function(r) {
          selectedOptions[r.name.replace('options[', '').replace(']', '')] = r.value;
        });
        
        // Find matching variant robustly using exact option order
        var matchedVariant = variants.find(function(v) {
          return productOptions.every(function(optName, idx) {
            var optKey = 'option' + (idx + 1);
            return v[optKey] === selectedOptions[optName];
          });
        });
        
        if (matchedVariant) {
          idInput.value = matchedVariant.id;
          
          // Update Price
          if (priceEl) {
            var formatter = new Intl.NumberFormat('en-IN', {
              style: 'currency',
              currency: 'INR',
              minimumFractionDigits: 0
            });
            priceEl.innerHTML = formatter.format(matchedVariant.price / 100);
          }
          
          // Update URL
          window.history.replaceState({}, '', '?variant=' + matchedVariant.id);
          
          // Update Availability
          if (matchedVariant.available) {
            if(btn) btn.disabled = false;
            if(btnText) btnText.innerHTML = 'Add to Cart';
            if(stickyCartBtn) stickyCartBtn.disabled = false;
            if(stickyCartBtnText) stickyCartBtnText.innerHTML = 'Add to Cart';
            if(stickyBuyBtn) stickyBuyBtn.disabled = false;
          } else {
            if(btn) btn.disabled = true;
            if(btnText) btnText.innerHTML = 'Sold Out';
            if(stickyCartBtn) stickyCartBtn.disabled = true;
            if(stickyCartBtnText) stickyCartBtnText.innerHTML = 'Sold Out';
            if(stickyBuyBtn) stickyBuyBtn.disabled = true;
          }
        }
      });
    });
  } catch(e) {
    console.error('Error parsing product variants', e);
  }
});
</script>

