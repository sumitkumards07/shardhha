<style>
.blog-page {
  padding: var(--section-spacing) 0;
  min-height: 60vh;
}
.blog-page__header {
  text-align: center;
  margin-bottom: 3rem;
}
.blog-page__title {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 5vw, 3.5rem);
  color: var(--color-dark-green);
  margin-bottom: 0.75rem;
}
.blog-page__desc {
  font-family: var(--font-body);
  color: var(--color-secondary-text);
  font-size: 1rem;
  max-width: 550px;
  margin: 0 auto;
  line-height: 1.7;
}

/* ── Article Card Grid ── */
.blog-grid {
  display: grid;
  grid-template-columns: repeat(1, 1fr);
  gap: 2rem;
}
@media (min-width: 640px) {
  .blog-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 1024px) {
  .blog-grid { grid-template-columns: repeat(3, 1fr); }
}

.blog-card {
  background: #FAF9F6;
  border: 1px solid var(--color-border);
  border-radius: 24px;
  overflow: hidden;
  transition: transform 0.4s ease, box-shadow 0.4s ease;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
}
.blog-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 12px 32px rgba(24,77,59,0.10);
}
.blog-card__image {
  aspect-ratio: 16/10;
  overflow: hidden;
}
.blog-card__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.7s ease;
}
.blog-card:hover .blog-card__image img {
  transform: scale(1.06);
}
.blog-card__body {
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  flex-grow: 1;
}
.blog-card__meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 0.75rem;
}
.blog-card__tag {
  font-family: var(--font-body);
  font-size: 0.7rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #FAF9F6;
  background: var(--color-dark-green);
  padding: 0.3rem 0.9rem;
  border-radius: 50px;
}
.blog-card__date {
  font-family: var(--font-body);
  font-size: 0.8rem;
  color: var(--color-secondary-text);
}
.blog-card__title {
  font-family: var(--font-heading);
  font-size: 1.2rem;
  font-weight: 500;
  color: var(--color-primary-text);
  line-height: 1.35;
  margin-bottom: 0.75rem;
  transition: color 0.3s ease;
}
.blog-card:hover .blog-card__title {
  color: var(--color-dark-green);
}
.blog-card__excerpt {
  font-family: var(--font-body);
  font-size: 0.9rem;
  color: var(--color-secondary-text);
  line-height: 1.6;
  margin-bottom: 1.5rem;
  flex-grow: 1;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.blog-card__read-more {
  font-family: var(--font-body);
  font-size: 0.8rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-dark-green);
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  margin-top: auto;
  transition: gap 0.3s ease;
}
.blog-card:hover .blog-card__read-more {
  gap: 0.8rem;
}
.blog-card__read-more svg {
  width: 16px;
  height: 16px;
}

/* ── Pagination ── */
.blog-pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 0.5rem;
  margin-top: 3rem;
  font-family: var(--font-body);
}
.blog-pagination a,
.blog-pagination span.current {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 44px;
  height: 44px;
  padding: 0 0.75rem;
  border-radius: 50px;
  font-size: 0.9rem;
  font-weight: 500;
  text-decoration: none;
  transition: all 0.3s ease;
}
.blog-pagination a {
  color: var(--color-primary-text);
  border: 1px solid var(--color-border);
}
.blog-pagination a:hover {
  background: var(--color-dark-green);
  color: #FAF9F6;
  border-color: var(--color-dark-green);
}
.blog-pagination span.current {
  background: var(--color-dark-green);
  color: #FAF9F6;
}

/* ── Empty State ── */
.blog-empty {
  text-align: center;
  padding: 4rem 0;
}
.blog-empty__icon {
  width: 72px;
  height: 72px;
  margin: 0 auto 1.5rem;
  color: var(--color-secondary-text);
  opacity: 0.35;
}
.blog-empty__text {
  font-family: var(--font-body);
  color: var(--color-secondary-text);
  font-size: 1.1rem;
  margin-bottom: 2rem;
}
</style>

<div class="blog-page">
  <div class="container">
    <div class="blog-page__header">
      <h1 class="blog-page__title">{{ blog.title | default: 'Journal' }}</h1>
      <p class="blog-page__desc">Stories of craft, culture, and the artisans behind every thread.</p>
    </div>

    {% paginate blog.articles by 9 %}
      {% if blog.articles.size > 0 %}
        <div class="blog-grid">
          {% for article in blog.articles %}
            <a href="{{ article.url }}" class="blog-card">
              <div class="blog-card__image">
                {% if article.image %}
                  {{ article.image | image_url: width: 800 | image_tag: alt: article.title }}
                {% else %}
                  <img src="https://images.unsplash.com/photo-1558618666-fcd25c85f82e?q=80&w=800&auto=format&fit=crop" alt="{{ article.title }}">
                {% endif %}
              </div>
              <div class="blog-card__body">
                <div class="blog-card__meta">
                  {% if article.tags.size > 0 %}
                    <span class="blog-card__tag">{{ article.tags.first }}</span>
                  {% endif %}
                  <span class="blog-card__date">{{ article.published_at | date: "%b %d, %Y" }}</span>
                </div>
                <h2 class="blog-card__title">{{ article.title }}</h2>
                <p class="blog-card__excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 25 }}</p>
                <span class="blog-card__read-more">
                  Read More
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          {% endfor %}
        </div>

        {% if paginate.pages > 1 %}
          <div class="blog-pagination">
            {{ paginate | default_pagination: next: 'Next →', previous: '← Previous' }}
          </div>
        {% endif %}
      {% else %}
        <div class="blog-empty">
          <svg class="blog-empty__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6m-6-4h10"/></svg>
          <p class="blog-empty__text">No articles published yet. Check back soon!</p>
          <a href="{{ routes.root_url }}" class="btn btn-primary">Back to Home</a>
        </div>
      {% endif %}
    {% endpaginate %}
  </div>
</div>

{% schema %}
{
  "name": "Blog Posts",
  "settings": []
}
{% endschema %}
