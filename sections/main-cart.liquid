<style>
.cart-page {
  padding: var(--section-spacing) 0;
  min-height: 50vh;
}
.cart-header {
  text-align: center;
  margin-bottom: 3rem;
}
.cart-title {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 4vw, 3rem);
  color: var(--color-dark-green);
}
.cart-empty {
  text-align: center;
  padding: 4rem 0;
}
.cart-empty-icon {
  width: 80px;
  height: 80px;
  margin: 0 auto 1.5rem;
  color: var(--color-secondary-text);
  opacity: 0.4;
}
.cart-empty-message {
  font-family: var(--font-body);
  color: var(--color-secondary-text);
  margin-bottom: 2rem;
  font-size: 1.1rem;
}
.cart-layout {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 3rem;
  align-items: start;
}
.cart-items {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}
.cart-item {
  display: flex;
  gap: 1.5rem;
  padding: 1.5rem;
  background: #FAF9F6;
  border: 1px solid var(--color-border);
  border-radius: 0px;
  transition: box-shadow 0.3s ease;
}
.cart-item:hover {
  box-shadow: 0 4px 16px rgba(0,0,0,0.05);
}
.cart-item__image {
  width: 100px;
  height: 130px;
  object-fit: cover;
  border-radius: 0px;
  flex-shrink: 0;
}
.cart-item__details {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.cart-item__title {
  font-weight: 600;
  color: var(--color-primary-text);
  text-decoration: none;
  font-family: var(--font-body);
  font-size: 1rem;
  line-height: 1.3;
}
.cart-item__variant {
  font-size: 0.85rem;
  color: var(--color-secondary-text);
  margin-top: 0.25rem;
}
.cart-item__price {
  font-family: var(--font-body);
  font-weight: 600;
  color: var(--color-dark-green);
  font-size: 1rem;
  margin-top: 0.5rem;
}
.cart-item__actions {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-top: 0.75rem;
}
.cart-item__qty {
  display: flex;
  align-items: center;
  border: 1px solid var(--color-border);
  border-radius: 0px;
  overflow: hidden;
}
.cart-item__qty-btn {
  background: none;
  border: none;
  padding: 0.5rem 0.75rem;
  cursor: pointer;
  font-size: 1rem;
  color: var(--color-primary-text);
  transition: background-color 0.2s ease;
}
.cart-item__qty-btn:hover {
  background-color: rgba(0,0,0,0.04);
}
.cart-item__qty-input {
  width: 40px;
  text-align: center;
  border: none;
  border-left: 1px solid var(--color-border);
  border-right: 1px solid var(--color-border);
  font-family: var(--font-body);
  font-size: 0.9rem;
  padding: 0.4rem 0;
  border-radius: 0 !important;
  background: transparent;
}
.cart-item__remove {
  font-size: 0.8rem;
  color: #c0392b;
  text-decoration: none;
  font-weight: 500;
  transition: all 0.3s ease;
  padding: 4px 12px;
  border-radius: 0px;
  border: 1px solid #c0392b;
}
.cart-item__remove:hover {
  background-color: #c0392b;
  color: #fff;
}

/* Summary */
.cart-summary {
  position: sticky;
  top: 120px;
  background: #FAF9F6;
  border: 1px solid var(--color-border);
  border-radius: 0px;
  padding: 2rem;
}
.cart-summary__title {
  font-family: var(--font-heading);
  font-size: 1.3rem;
  color: var(--color-dark-green);
  margin-bottom: 1.5rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--color-border);
}
.cart-summary__row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 1rem;
  font-family: var(--font-body);
  font-size: 0.95rem;
  color: var(--color-primary-text);
}
.cart-summary__row--total {
  font-weight: 600;
  font-size: 1.15rem;
  padding-top: 1rem;
  border-top: 1px solid var(--color-border);
  margin-top: 0.5rem;
}
.cart-summary__note {
  font-size: 0.8rem;
  color: var(--color-secondary-text);
  margin-bottom: 1.5rem;
  text-align: center;
}
.cart-summary__btn {
  width: 100%;
  background-color: var(--color-dark-green);
  color: #FAF9F6;
  padding: 1rem;
  border: none;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  cursor: pointer;
  border-radius: 0px;
  font-family: var(--font-body);
  font-size: 0.9rem;
  font-weight: 600;
  transition: all 0.3s ease;
  margin-bottom: 0.75rem;
}
.cart-summary__btn:hover {
  background-color: var(--color-muted-gold);
}
.cart-summary__btn--secondary {
  background-color: transparent;
  color: var(--color-primary-text);
  border: 1px solid var(--color-border);
}
.cart-summary__btn--secondary:hover {
  background-color: rgba(0,0,0,0.03);
}

@media (max-width: 768px) {
  .cart-layout {
    grid-template-columns: 1fr;
  }
  .cart-item {
    padding: 1rem;
  }
  .cart-item__image {
    width: 80px;
    height: 100px;
    border-radius: 0px;
  }
  .cart-summary {
    position: static;
  }
}
</style>

<div class="cart-page">
  <div class="container">
    <div class="cart-header">
      <h1 class="cart-title">Your Cart</h1>
    </div>

    {% if cart.item_count > 0 %}
      <form action="{{ routes.cart_url }}" method="post" id="cart">
        <div class="cart-layout">
          <div class="cart-items">
            {% for item in cart.items %}
              <div class="cart-item">
                {% if item.image %}
                  <a href="{{ item.url }}">
                    {{ item.image | image_url: width: 200 | image_tag: class: 'cart-item__image', alt: item.title }}
                  </a>
                {% endif %}
                <div class="cart-item__details">
                  <div>
                    <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                    {% unless item.product.has_only_default_variant %}
                      <p class="cart-item__variant">{{ item.variant.title }}</p>
                    {% endunless %}
                    <div class="cart-item__price">{{ item.price | money }}</div>
                  </div>
                  <div class="cart-item__actions">
                    <div class="cart-item__qty">
                      <button type="button" class="cart-item__qty-btn" onclick="this.nextElementSibling.stepDown(); this.closest('form').submit();">−</button>
                      <input type="number" name="updates[]" id="updates_{{ item.key }}" value="{{ item.quantity }}" min="0" class="cart-item__qty-input">
                      <button type="button" class="cart-item__qty-btn" onclick="this.previousElementSibling.stepUp(); this.closest('form').submit();">+</button>
                    </div>
                    <a href="{{ item.url_to_remove }}" class="cart-item__remove">Remove</a>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>

          <div class="cart-summary">
            <h3 class="cart-summary__title">Order Summary</h3>
            <div class="cart-summary__row">
              <span>Subtotal</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            <div class="cart-summary__row">
              <span>Shipping</span>
              <span style="color: var(--color-dark-green); font-weight: 500;">Free</span>
            </div>
            <div class="cart-summary__row cart-summary__row--total">
              <span>Total</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            <p class="cart-summary__note">Taxes calculated at checkout</p>
            <button type="submit" name="checkout" class="cart-summary__btn">Proceed to Checkout</button>
            <button type="submit" name="update" class="cart-summary__btn cart-summary__btn--secondary">Update Cart</button>
          </div>
        </div>
      </form>
    {% else %}
      <div class="cart-empty">
        <svg class="cart-empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0"/></svg>
        <p class="cart-empty-message">Your cart is currently empty.</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary">Continue Shopping</a>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Cart page",
  "settings": []
}
{% endschema %}
