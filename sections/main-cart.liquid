<style>
.cart-page {
  padding: var(--section-spacing) 0;
  background-color: var(--color-soft-beige);
  min-height: 50vh;
}
.cart-header {
  text-align: center;
  margin-bottom: 3rem;
}
.cart-title {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 4vw, 3rem);
  color: var(--color-dark-green);
}
.cart-empty {
  text-align: center;
}
.cart-empty-message {
  font-family: var(--font-body);
  color: var(--color-secondary-text);
  margin-bottom: 2rem;
}
.cart-table {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: 2rem;
}
.cart-table th {
  text-align: left;
  text-transform: uppercase;
  font-size: 0.85rem;
  letter-spacing: 0.05em;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--color-border);
  color: var(--color-secondary-text);
}
.cart-table td {
  padding: 1.5rem 0;
  border-bottom: 1px solid var(--color-border);
}
.cart-item-details {
  display: flex;
  gap: 1.5rem;
  align-items: center;
}
.cart-item-image {
  width: 80px;
  height: 100px;
  object-fit: cover;
}
.cart-item-title {
  font-weight: 600;
  color: var(--color-primary-text);
  text-decoration: none;
  font-family: var(--font-body);
  display: block;
  margin-bottom: 0.25rem;
}
.cart-item-variant {
  font-size: 0.85rem;
  color: var(--color-secondary-text);
}
.cart-item-remove {
  font-size: 0.85rem;
  color: #d9534f;
  text-decoration: none;
  margin-top: 0.5rem;
  display: inline-block;
}
.cart-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 2rem;
}
.cart-summary {
  width: 100%;
  max-width: 400px;
  background: #FAF9F6;
  padding: 2rem;
  box-shadow: var(--shadow-sm);
}
.cart-subtotal {
  display: flex;
  justify-content: space-between;
  margin-bottom: 1.5rem;
  font-family: var(--font-heading);
  font-size: 1.25rem;
  color: var(--color-primary-text);
}
.cart-checkout-btn {
  width: 100%;
  background-color: var(--color-dark-green);
  color: #FAF9F6;
  padding: 1rem;
  border: none;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  cursor: pointer;
}
.cart-checkout-btn:hover {
  background-color: var(--color-muted-gold);
}

@media (max-width: 768px) {
  .cart-table thead {
    display: none;
  }
  .cart-table, .cart-table tbody, .cart-table tr, .cart-table td {
    display: block;
    width: 100%;
  }
  .cart-table tr {
    margin-bottom: 1rem;
  }
  .cart-item-price, .cart-item-quantity, .cart-item-total {
    text-align: right;
    padding: 0.5rem 0;
  }
}
</style>

<div class="cart-page">
  <div class="container">
    <div class="cart-header">
      <h1 class="cart-title">Your Cart</h1>
    </div>

    {% if cart.item_count > 0 %}
      <form action="{{ routes.cart_url }}" method="post" id="cart">
        <table class="cart-table">
          <thead>
            <tr>
              <th>Product</th>
              <th>Price</th>
              <th>Quantity</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody>
            {% for item in cart.items %}
              <tr>
                <td>
                  <div class="cart-item-details">
                    {% if item.image %}
                      <a href="{{ item.url }}">
                        {{ item.image | image_url: width: 160 | image_tag: class: 'cart-item-image', alt: item.title }}
                      </a>
                    {% endif %}
                    <div>
                      <a href="{{ item.url }}" class="cart-item-title">{{ item.product.title }}</a>
                      {% unless item.product.has_only_default_variant %}
                        <p class="cart-item-variant">{{ item.variant.title }}</p>
                      {% endunless %}
                      <a href="{{ item.url_to_remove }}" class="cart-item-remove">Remove</a>
                    </div>
                  </div>
                </td>
                <td class="cart-item-price">{{ item.price | money }}</td>
                <td class="cart-item-quantity">
                  <input type="number" name="updates[]" id="updates_{{ item.key }}" value="{{ item.quantity }}" min="0" style="width: 60px; padding: 0.5rem; text-align: center; border: 1px solid var(--color-border);">
                </td>
                <td class="cart-item-total">{{ item.final_line_price | money }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>

        <div class="cart-footer">
          <div class="cart-summary">
            <div class="cart-subtotal">
              <span>Subtotal</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            <p style="font-size: 0.85rem; color: var(--color-secondary-text); margin-bottom: 1.5rem;">Taxes and shipping calculated at checkout.</p>
            <button type="submit" name="update" class="btn btn-secondary" style="width: 100%; margin-bottom: 1rem;">Update Cart</button>
            <button type="submit" name="checkout" class="cart-checkout-btn">Proceed to Checkout</button>
          </div>
        </div>
      </form>
    {% else %}
      <div class="cart-empty">
        <p class="cart-empty-message">Your cart is currently empty.</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn-secondary">Continue Shopping</a>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Cart page",
  "settings": []
}
{% endschema %}
