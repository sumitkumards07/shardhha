<style>
  /* ── Our Story Page Layout ── */
  .story-page {
    background-color: var(--color-warm-ivory);
    color: var(--color-primary-text);
    padding-bottom: 5rem;
    overflow-x: hidden;
  }

  /* ── 1. Editorial Hero ── */
  .story-hero {
    position: relative;
    width: 100vw;
    height: 80vh;
    min-height: 500px;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }
  .story-hero__img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85; /* slight dimming for text readability */
    z-index: 1;
  }
  .story-hero__content {
    position: relative;
    z-index: 2;
    padding: 0 1.25rem;
    max-width: 800px;
  }
  .story-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    color: #FAF9F6;
    line-height: 1.1;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
    text-shadow: 0 2px 10px rgba(0,0,0,0.2);
  }
  .story-hero__subtitle {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: #FAF9F6;
    font-weight: 300;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-shadow: 0 1px 5px rgba(0,0,0,0.2);
  }

  @media (max-width: 767px) {
    .story-hero {
      height: 70vh;
    }
  }

  /* ── 2. The Narrative (Text Block) ── */
  .story-narrative {
    padding: 6rem 1.25rem;
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }
  .story-narrative__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    color: var(--color-dark-green);
    margin-bottom: 2rem;
    line-height: 1.2;
  }
  .story-narrative__body {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-secondary-text);
    margin-bottom: 1.5rem;
  }
  .story-narrative__body:last-child {
    margin-bottom: 0;
  }
  
  @media (max-width: 767px) {
    .story-narrative { padding: 4rem 1.25rem; }
  }

  /* ── 3. Pillars of Craftsmanship ── */
  .story-pillars {
    padding: 2rem 1.25rem 6rem;
    max-width: var(--max-width, 1200px);
    margin: 0 auto;
  }
  .story-pillars__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }
  .story-pillar {
    text-align: center;
    padding: 2rem;
    border: 1px solid var(--color-border);
    transition: transform 0.4s ease;
  }
  .story-pillar:hover {
    transform: translateY(-5px);
  }
  .story-pillar__icon {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    color: var(--color-muted-gold);
    margin-bottom: 1rem;
    font-style: italic;
  }
  .story-pillar__title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: var(--color-dark-green);
    margin-bottom: 1rem;
  }
  .story-pillar__text {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-secondary-text);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .story-pillars__grid { gap: 1.5rem; }
    .story-pillar { padding: 1.5rem; }
  }
  @media (max-width: 767px) {
    .story-pillars { padding: 0 1.25rem 4rem; }
    .story-pillars__grid { grid-template-columns: 1fr; gap: 1rem; }
    .story-pillar { padding: 2rem 1.5rem; }
  }

  /* ── 4. CTA Section ── */
  .story-cta {
    text-align: center;
    padding: 2rem 1.25rem 4rem;
  }
</style>

<div class="story-page">
  
  <!-- 1. Hero -->
  <div class="story-hero">
    <img class="story-hero__img" src="{{ 'our_story_hero.png' | asset_url }}" alt="Elegant Indian woman in heritage courtyard">
    <div class="story-hero__content">
      <h1 class="story-hero__title">Crafted With Heritage</h1>
      <p class="story-hero__subtitle">Rooted in Culture, Woven for Today</p>
    </div>
  </div>

  <!-- 2. Narrative -->
  <div class="story-narrative">
    <h2 class="story-narrative__heading">The Thread of Tradition</h2>
    <p class="story-narrative__body">
      At Sharddha Weaves, we believe that true luxury lies in the hands of the artisan. Our journey began with a singular vision: to bring the breathtaking heritage of Indian textiles to the modern wardrobe, untouched by the haste of mass production.
    </p>
    <p class="story-narrative__body">
      Every kurti and saree in our collection is a testament to timeless elegance. We travel to the heart of India's weaving clusters to source the finest cottons, silks, and handlooms. By marrying traditional motifs with contemporary, minimalist silhouettes, we create fashion that isn't just worn, but cherished.
    </p>
    <p class="story-narrative__body">
      This is quiet luxury, inspired by centuries of artistry, designed for the sophisticated woman of today.
    </p>
  </div>

  <!-- 3. Pillars Grid -->
  <div class="story-pillars">
    <div class="story-pillars__grid">
      
      <div class="story-pillar">
        <div class="story-pillar__icon">I</div>
        <h3 class="story-pillar__title">Handwoven Authenticity</h3>
        <p class="story-pillar__text">We partner directly with master weavers, ensuring every thread honors the rich legacy of Indian craftsmanship while supporting ethical artisan communities.</p>
      </div>

      <div class="story-pillar">
        <div class="story-pillar__icon">II</div>
        <h3 class="story-pillar__title">Timeless Silhouettes</h3>
        <p class="story-pillar__text">Our designs reject fleeting trends. We focus on clean lines, flawless fits, and elegant simplicity that remain breathtaking season after season.</p>
      </div>

      <div class="story-pillar">
        <div class="story-pillar__icon">III</div>
        <h3 class="story-pillar__title">Conscious Luxury</h3>
        <p class="story-pillar__text">True luxury is sustainable. From breathable organic cottons to pure handspun silks, we prioritize natural fabrics that are as kind to the earth as they are to your skin.</p>
      </div>

    </div>
  </div>

  <!-- 4. CTA -->
  <div class="story-cta">
    <a href="/collections/all" class="btn btn-primary">Shop The Heritage Collection</a>
  </div>

</div>

{% schema %}
{
  "name": "Our Story",
  "settings": [],
  "presets": [
    {
      "name": "Our Story"
    }
  ]
}
{% endschema %}
