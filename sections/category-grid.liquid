<style>
.category-grid {
  padding-top: calc(var(--section-spacing) / 1.5);
  padding-bottom: calc(var(--section-spacing) / 1.5);
  background-color: var(--color-soft-beige);
}
.category-grid__header {
  text-align: center;
  margin-bottom: 2rem;
}
.category-grid__title {
  font-family: var(--font-heading);
  font-size: 2rem;
  color: var(--color-primary-text);
  margin: 0;
}
.category-grid__items {
  display: flex;
  justify-content: center;
  gap: 2rem;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding-bottom: 1rem;
}
.category-grid__items::-webkit-scrollbar {
  display: none;
}
.category-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-decoration: none;
  width: 150px;
  flex: 0 0 auto;
  scroll-snap-align: center;
}
@media (max-width: 768px) {
  .category-grid__items {
    justify-content: flex-start;
    padding-left: 1rem;
    padding-right: 1rem;
    gap: 1rem;
  }
  .category-card {
    width: 65px;
  }
  .category-card__image-wrapper {
    width: 60px;
    height: 60px;
  }
  .category-card__title {
    font-size: 0.75rem;
  }
}
.category-card__image-wrapper {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 1rem;
  border: 2px solid transparent;
  transition: border-color 0.3s ease;
}
.category-card:hover .category-card__image-wrapper {
  border-color: var(--color-dark-green);
}
.category-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}
.category-card:hover .category-card__image {
  transform: scale(1.1);
}
.category-card__title {
  font-family: var(--font-body);
  font-size: 0.9rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--color-primary-text);
  text-align: center;
}
</style>

<section class="category-grid">
  <div class="container">
    {% if section.settings.title != blank %}
      <div class="category-grid__header">
        <h2 class="category-grid__title">{{ section.settings.title }}</h2>
      </div>
    {% endif %}

    <div class="category-grid__items">
      {% for block in section.blocks %}
        <a href="{{ block.settings.collection.url | default: '#' }}" class="category-card">
          <div class="category-card__image-wrapper">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 300 | image_tag: class: 'category-card__image', alt: block.settings.title }}
            {% elsif block.settings.collection.image != blank %}
               {{ block.settings.collection.image | image_url: width: 300 | image_tag: class: 'category-card__image', alt: block.settings.title }}
            {% else %}
              {% if forloop.index == 1 %}
                <img src="https://images.unsplash.com/photo-1583391733958-d25e07fac66e?q=80&w=600&auto=format&fit=crop" class="category-card__image" alt="Category">
              {% elsif forloop.index == 2 %}
                <img src="https://images.unsplash.com/photo-1610030469983-98e550d6193c?q=80&w=600&auto=format&fit=crop" class="category-card__image" alt="Category">
              {% elsif forloop.index == 3 %}
                <img src="https://images.unsplash.com/photo-1583391733975-d25e07fac66e?q=80&w=600&auto=format&fit=crop" class="category-card__image" alt="Category">
              {% else %}
                <img src="https://images.unsplash.com/photo-1550617931-e17a7b70dce2?q=80&w=600&auto=format&fit=crop" class="category-card__image" alt="Category">
              {% endif %}
            {% endif %}
          </div>
          <div class="category-card__title">{{ block.settings.title | default: block.settings.collection.title | default: 'Category' }}</div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category Grid (Circular)",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop by Category"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "limit": 6,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image (optional)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom Title (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Grid (Circular)",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
