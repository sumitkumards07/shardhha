<style>
.category-grid {
  padding-top: calc(var(--section-spacing) / 1.5);
  padding-bottom: calc(var(--section-spacing) / 1.5);
  background-color: var(--color-soft-beige);
}
.category-grid__header {
  text-align: center;
  margin-bottom: 2rem;
}
.category-grid__title {
  font-family: var(--font-heading);
  font-size: 2rem;
  color: var(--color-primary-text);
  margin: 0;
}
.category-grid__items {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 2rem;
}
.category-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-decoration: none;
  width: 150px;
}
.category-card__image-wrapper {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 1rem;
  border: 2px solid transparent;
  transition: border-color 0.3s ease;
}
.category-card:hover .category-card__image-wrapper {
  border-color: var(--color-dark-green);
}
.category-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}
.category-card:hover .category-card__image {
  transform: scale(1.1);
}
.category-card__title {
  font-family: var(--font-body);
  font-size: 0.9rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--color-primary-text);
  text-align: center;
}
</style>

<section class="category-grid">
  <div class="container">
    {% if section.settings.title != blank %}
      <div class="category-grid__header">
        <h2 class="category-grid__title">{{ section.settings.title }}</h2>
      </div>
    {% endif %}

    <div class="category-grid__items">
      {% for block in section.blocks %}
        <a href="{{ block.settings.collection.url | default: '#' }}" class="category-card">
          <div class="category-card__image-wrapper">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 300 | image_tag: class: 'category-card__image', alt: block.settings.title }}
            {% elsif block.settings.collection.image != blank %}
               {{ block.settings.collection.image | image_url: width: 300 | image_tag: class: 'category-card__image', alt: block.settings.title }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg category-card__image' }}
            {% endif %}
          </div>
          <div class="category-card__title">{{ block.settings.title | default: block.settings.collection.title | default: 'Category' }}</div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category Grid (Circular)",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop by Category"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "limit": 6,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Image (optional)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom Title (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Grid (Circular)",
      "blocks": [
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" },
        { "type": "category" }
      ]
    }
  ]
}
{% endschema %}
