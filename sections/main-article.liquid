<style>
.article-page {
  padding: var(--section-spacing) 0;
}

/* ── Hero Banner ── */
.article-hero {
  position: relative;
  aspect-ratio: 21/9;
  border-radius: 24px;
  overflow: hidden;
  margin-bottom: 3rem;
  max-height: 450px;
}
.article-hero img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.article-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 60%);
}

/* ── Article Content ── */
.article-content-wrapper {
  max-width: 760px;
  margin: 0 auto;
}
.article-meta {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}
.article-meta__tag {
  font-family: var(--font-body);
  font-size: 0.7rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #FAF9F6;
  background: var(--color-dark-green);
  padding: 0.3rem 0.9rem;
  border-radius: 50px;
}
.article-meta__date,
.article-meta__author {
  font-family: var(--font-body);
  font-size: 0.85rem;
  color: var(--color-secondary-text);
}
.article-meta__dot {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: var(--color-secondary-text);
  opacity: 0.5;
}
.article-title {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 5vw, 3rem);
  color: var(--color-dark-green);
  line-height: 1.15;
  margin-bottom: 2rem;
}

/* ── Article Body ── */
.article-body {
  font-family: var(--font-body);
  font-size: 1.1rem;
  line-height: 1.85;
  color: var(--color-primary-text);
}
.article-body h2 {
  font-family: var(--font-heading);
  font-size: 1.6rem;
  color: var(--color-dark-green);
  margin-top: 2.5rem;
  margin-bottom: 1rem;
}
.article-body h3 {
  font-family: var(--font-heading);
  font-size: 1.3rem;
  color: var(--color-dark-green);
  margin-top: 2rem;
  margin-bottom: 0.75rem;
}
.article-body p {
  margin-bottom: 1.5rem;
}
.article-body img {
  border-radius: 20px;
  margin: 2rem 0;
  width: 100%;
  height: auto;
}
.article-body blockquote {
  border-left: 3px solid var(--color-dark-green);
  padding: 1rem 0 1rem 1.5rem;
  margin: 2rem 0;
  font-style: italic;
  color: var(--color-secondary-text);
  font-size: 1.15rem;
}
.article-body ul, .article-body ol {
  padding-left: 1.5rem;
  margin: 1rem 0 1.5rem;
}
.article-body li {
  margin-bottom: 0.5rem;
}
.article-body a {
  color: var(--color-dark-green);
  text-decoration: underline;
  text-underline-offset: 3px;
}

/* ── Share & Back ── */
.article-footer {
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid var(--color-border);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
}
.article-back {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-body);
  font-size: 0.85rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-dark-green);
  text-decoration: none;
  padding: 0.75rem 1.5rem;
  border: 1px solid var(--color-dark-green);
  border-radius: 50px;
  transition: all 0.3s ease;
}
.article-back:hover {
  background: var(--color-dark-green);
  color: #FAF9F6;
}
.article-back svg {
  width: 16px;
  height: 16px;
}
.article-share {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.article-share__label {
  font-family: var(--font-body);
  font-size: 0.8rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-secondary-text);
}
.article-share__link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border-radius: 50%;
  border: 1px solid var(--color-border);
  color: var(--color-primary-text);
  transition: all 0.3s ease;
  text-decoration: none;
}
.article-share__link:hover {
  background: var(--color-dark-green);
  border-color: var(--color-dark-green);
  color: #FAF9F6;
}
.article-share__link svg {
  width: 16px;
  height: 16px;
}

/* ── Comments ── */
.article-comments {
  max-width: 760px;
  margin: 3rem auto 0;
  padding-top: 2rem;
  border-top: 1px solid var(--color-border);
}
.article-comments__title {
  font-family: var(--font-heading);
  font-size: 1.5rem;
  color: var(--color-dark-green);
  margin-bottom: 2rem;
}
.comment-form__group {
  margin-bottom: 1rem;
}
.comment-form__input,
.comment-form__textarea {
  width: 100%;
  padding: 0.9rem 1.25rem;
  border: 1px solid var(--color-border);
  border-radius: 14px;
  font-family: var(--font-body);
  font-size: 0.95rem;
  background: #FAF9F6;
  outline: none;
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}
.comment-form__input:focus,
.comment-form__textarea:focus {
  border-color: var(--color-dark-green);
  box-shadow: 0 0 0 3px rgba(15,45,36,0.08);
}
.comment-form__textarea {
  min-height: 120px;
  resize: vertical;
}
.comment-form__row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}
.comment-form__btn {
  background: var(--color-dark-green);
  color: #FAF9F6;
  border: none;
  padding: 0.9rem 2.5rem;
  border-radius: 50px;
  font-family: var(--font-body);
  font-size: 0.85rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  cursor: pointer;
  transition: background-color 0.3s ease;
  margin-top: 0.5rem;
}
.comment-form__btn:hover {
  background-color: var(--color-muted-gold);
}

@media (max-width: 768px) {
  .article-hero {
    aspect-ratio: 16/9;
    border-radius: 18px;
  }
  .comment-form__row {
    grid-template-columns: 1fr;
  }
}
</style>

<div class="article-page">
  <div class="container">
    
    <!-- Hero Image -->
    {% if article.image %}
      <div class="article-hero">
        {{ article.image | image_url: width: 1600 | image_tag: alt: article.title }}
        <div class="article-hero__overlay"></div>
      </div>
    {% endif %}

    <div class="article-content-wrapper">
      
      <!-- Meta -->
      <div class="article-meta">
        {% if article.tags.size > 0 %}
          <span class="article-meta__tag">{{ article.tags.first }}</span>
        {% endif %}
        <span class="article-meta__date">{{ article.published_at | date: "%B %d, %Y" }}</span>
        <span class="article-meta__dot"></span>
        <span class="article-meta__author">by {{ article.author }}</span>
      </div>

      <!-- Title -->
      <h1 class="article-title">{{ article.title }}</h1>

      <!-- Body Content -->
      <div class="article-body">
        {{ article.content }}
      </div>

      <!-- Footer -->
      <div class="article-footer">
        <a href="{{ blog.url }}" class="article-back">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Back to {{ blog.title | default: 'Blog' }}
        </a>
        <div class="article-share">
          <span class="article-share__label">Share</span>
          <a href="https://twitter.com/intent/tweet?url={{ article.url | prepend: shop.url }}&text={{ article.title | url_encode }}" target="_blank" rel="noopener" class="article-share__link" aria-label="Share on Twitter">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/></svg>
          </a>
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ article.url | prepend: shop.url }}" target="_blank" rel="noopener" class="article-share__link" aria-label="Share on Facebook">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Comments -->
    {% if blog.comments_enabled? %}
      <div class="article-comments">
        <h2 class="article-comments__title">
          {% if article.comments_count > 0 %}
            {{ article.comments_count }} Comment{% if article.comments_count != 1 %}s{% endif %}
          {% else %}
            Leave a Comment
          {% endif %}
        </h2>

        {% for comment in article.comments %}
          <div style="padding: 1.25rem; background: #FAF9F6; border: 1px solid var(--color-border); border-radius: 16px; margin-bottom: 1rem;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
              <strong style="font-size: 0.9rem; color: var(--color-dark-green);">{{ comment.author }}</strong>
              <span style="font-size: 0.8rem; color: var(--color-secondary-text);">{{ comment.created_at | date: "%b %d, %Y" }}</span>
            </div>
            <p style="font-size: 0.95rem; line-height: 1.6; color: var(--color-primary-text);">{{ comment.content }}</p>
          </div>
        {% endfor %}

        {% form 'new_comment', article %}
          <div class="comment-form__row">
            <div class="comment-form__group">
              <input type="text" name="comment[author]" class="comment-form__input" placeholder="Name" required>
            </div>
            <div class="comment-form__group">
              <input type="email" name="comment[email]" class="comment-form__input" placeholder="Email" required>
            </div>
          </div>
          <div class="comment-form__group">
            <textarea name="comment[body]" class="comment-form__textarea" placeholder="Write your comment..." required></textarea>
          </div>
          <button type="submit" class="comment-form__btn">Post Comment</button>
        {% endform %}
      </div>
    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "Article",
  "settings": []
}
{% endschema %}
