<style>
.footer {
  background-color: var(--color-warm-ivory);
  color: var(--color-primary-text);
  padding: 5rem 0 2rem;
  font-family: var(--font-body);
}
.footer__inner {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 3rem;
  margin-bottom: 4rem;
}
.footer__block-title {
  font-family: var(--font-heading);
  font-size: 1.3rem;
  margin-bottom: 1.5rem;
  color: var(--color-dark-green);
}
.footer__logo {
  font-family: var(--font-heading);
  font-size: 1.8rem;
  margin-bottom: 1rem;
  display: block;
  text-decoration: none;
  color: var(--color-dark-green);
}
.footer__block p {
  color: var(--color-primary-text);
  line-height: 1.7;
  font-size: 0.95rem;
}
.footer__menu {
  list-style: none;
  padding: 0;
  margin: 0;
}
.footer__menu-item {
  margin-bottom: 0.8rem;
}
.footer__menu-link {
  color: var(--color-primary-text);
  text-decoration: none;
  font-size: 0.95rem;
  transition: color 0.3s ease, padding-left 0.3s ease;
  display: inline-block;
}
.footer__menu-link:hover {
  color: var(--color-dark-green);
  padding-left: 4px;
}
.footer__bottom {
  text-align: center;
  padding-top: 2rem;
  border-top: 1px solid var(--color-border);
  font-size: 0.85rem;
  color: var(--color-secondary-text);
}
.footer__social {
  display: flex;
  gap: 1rem;
  margin-top: 1.5rem;
}
.footer__social-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid var(--color-border);
  color: var(--color-primary-text);
  transition: all 0.3s ease;
}
.footer__social-link:hover {
  background-color: var(--color-dark-green);
  border-color: var(--color-dark-green);
  color: #FAF9F6;
}
.footer__social-link svg {
  width: 18px;
  height: 18px;
}
@media (max-width: 768px) {
  .footer {
    padding: 3rem 0 1.5rem;
  }
  .footer__inner {
    grid-template-columns: 1fr;
    text-align: center;
    gap: 2rem;
    margin-bottom: 2rem;
  }
  .footer__logo {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .footer__block p {
    font-size: 0.85rem !important;
  }
  .footer__block-title {
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }
  .footer__menu {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.8rem 1.5rem;
  }
  .footer__menu-item {
    margin-bottom: 0;
  }
  .footer__menu-link {
    font-size: 0.85rem;
  }
  .footer__menu-link:hover {
    padding-left: 0;
  }
  .footer__social {
    justify-content: center;
  }
}
</style>

<footer class="footer">
  <div class="container">
    <div class="footer__inner">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'text' %}
            <!-- Brand / Text Block -->
            <div class="footer__block" {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}
                <a href="{{ routes.root_url }}" class="footer__logo">
                  {{ block.settings.heading }}
                </a>
              {% endif %}
              {% if block.settings.text != blank %}
                <p>{{ block.settings.text | newline_to_br }}</p>
              {% endif %}
              
              {% if block.settings.show_social %}
                <div class="footer__social">
                  {% if settings.social_instagram_link != blank %}
                    <a href="{{ settings.social_instagram_link }}" class="footer__social-link" aria-label="Instagram">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                    </a>
                  {% endif %}
                  {% if settings.social_facebook_link != blank %}
                    <a href="{{ settings.social_facebook_link }}" class="footer__social-link" aria-label="Facebook">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
                    </a>
                  {% endif %}
                  {% if settings.social_twitter_link != blank %}
                    <a href="{{ settings.social_twitter_link }}" class="footer__social-link" aria-label="Twitter">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/></svg>
                    </a>
                  {% endif %}
                </div>
              {% endif %}
            </div>
            
          {% when 'link_list' %}
            <!-- Menu Block -->
            <div class="footer__block" {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}
                <h3 class="footer__block-title">{{ block.settings.heading }}</h3>
              {% endif %}
              
              {% if block.settings.menu != blank and linklists[block.settings.menu].links.size > 0 %}
                <ul class="footer__menu">
                  {% for link in linklists[block.settings.menu].links %}
                    <li class="footer__menu-item"><a href="{{ link.url }}" class="footer__menu-link">{{ link.title }}</a></li>
                  {% endfor %}
                </ul>
              {% else %}
                <ul class="footer__menu">
                  {% if block.settings.heading == 'Policies' %}
                    <li class="footer__menu-item"><a href="/policies/privacy-policy" class="footer__menu-link">Privacy Policy</a></li>
                    <li class="footer__menu-item"><a href="/policies/refund-policy" class="footer__menu-link">Refund & Cancellation Policy</a></li>
                    <li class="footer__menu-item"><a href="/policies/terms-of-service" class="footer__menu-link">Terms of Service</a></li>
                  {% else %}
                    <li class="footer__menu-item"><a href="/pages/story" class="footer__menu-link">Our Story</a></li>
                    <li class="footer__menu-item"><a href="/collections/all" class="footer__menu-link">Shop All</a></li>
                    <li class="footer__menu-item"><a href="/pages/contact" class="footer__menu-link">Contact Us</a></li>
                  {% endif %}
                </ul>
              {% endif %}
            </div>
            
        {% endcase %}
      {% endfor %}
    </div>

    <div class="footer__bottom">
      &copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All Rights Reserved.
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "max_blocks": 4,
  "settings": [],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Quick links",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Store details",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "default": "Share store details, promotions, or brand content with your customers.",
          "label": "Text"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "default": true,
          "label": "Show social media icons"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "text",
        "settings": {
          "heading": "SHARDDHA WEAVES",
          "text": "Rooted in culture, woven for today. Premium ethnic fashion celebrating craftsmanship and timeless elegance.\n\nAngad Yadav\nLahartara, Varanasi 221106"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Quick links",
          "menu": "footer"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Policies",
          "menu": "footer"
        }
      }
    ]
  }
}
{% endschema %}
