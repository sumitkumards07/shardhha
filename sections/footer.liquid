<style>
.footer {
  background-color: var(--color-warm-ivory);
  color: var(--color-primary-text);
  padding: 5rem 0 2rem;
  font-family: var(--font-body);
}
.footer__inner {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 3rem;
  margin-bottom: 4rem;
}
.footer__block-title {
  font-family: var(--font-heading);
  font-size: 1.5rem;
  margin-bottom: 1.5rem;
  color: var(--color-dark-green);
}
.footer__logo {
  font-family: var(--font-heading);
  font-size: 2rem;
  margin-bottom: 1rem;
  display: block;
  text-decoration: none;
  color: var(--color-dark-green);
}
.footer__menu {
  list-style: none;
  padding: 0;
  margin: 0;
}
.footer__menu-item {
  margin-bottom: 0.8rem;
}
.footer__menu-link {
  color: var(--color-primary-text);
  text-decoration: none;
  font-size: 0.95rem;
  transition: color 0.3s ease;
}
.footer__menu-link:hover {
  color: var(--color-dark-green);
}
.footer__bottom {
  text-align: center;
  padding-top: 2rem;
  border-top: 1px solid var(--color-border);
  font-size: 0.85rem;
  color: var(--color-secondary-text);
}
@media (max-width: 768px) {
  .footer {
    padding: 3rem 0 1.5rem;
  }
  .footer__inner {
    grid-template-columns: 1fr;
    text-align: center;
    gap: 2rem;
    margin-bottom: 2rem;
  }
  .footer__logo {
    font-size: 1.6rem;
    margin-bottom: 0.5rem;
  }
  .footer__block p {
    font-size: 0.85rem !important;
  }
  .footer__block-title {
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }
  .footer__menu {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.8rem 1.5rem;
  }
  .footer__menu-item {
    margin-bottom: 0;
  }
  .footer__menu-link {
    font-size: 0.85rem;
  }
}
</style>

<footer class="footer">
  <div class="container">
    <div class="footer__inner">
      <!-- Brand Block -->
      <div class="footer__block">
        <a href="{{ routes.root_url }}" class="footer__logo">
          {{ shop.name | default: 'SHARDDHA WEAVES' }}
        </a>
        <p style="color: var(--color-primary-text); line-height: 1.6; font-size: 0.95rem;">
          Rooted in culture, woven for today. Premium ethnic fashion celebrating craftsmanship and timeless elegance.
        </p>
      </div>

      <!-- Quick Links Block -->
      <div class="footer__block">
        <h3 class="footer__block-title">Quick Links</h3>
        <ul class="footer__menu">
          {% for link in linklists.footer.links %}
            <li class="footer__menu-item"><a href="{{ link.url }}" class="footer__menu-link">{{ link.title }}</a></li>
          {% else %}
            <!-- Demo Links if no menu is selected -->
            <li class="footer__menu-item"><a href="#" class="footer__menu-link">About Us</a></li>
            <li class="footer__menu-item"><a href="#" class="footer__menu-link">Contact Us</a></li>
            <li class="footer__menu-item"><a href="#" class="footer__menu-link">Track Your Order</a></li>
            <li class="footer__menu-item"><a href="#" class="footer__menu-link">Return & Exchange</a></li>
          {% endfor %}
        </ul>
      </div>

      <!-- Policies Block -->
      <div class="footer__block">
        <h3 class="footer__block-title">Policies</h3>
        <ul class="footer__menu">
          {% for link in linklists.policies.links %}
            <li class="footer__menu-item"><a href="{{ link.url }}" class="footer__menu-link">{{ link.title }}</a></li>
          {% else %}
             <!-- Demo Links -->
            <li class="footer__menu-item"><a href="#" class="footer__menu-link">Privacy Policy</a></li>
            <li class="footer__menu-item"><a href="#" class="footer__menu-link">Shipping & Delivery Policy</a></li>
            <li class="footer__menu-item"><a href="#" class="footer__menu-link">Refund Policy</a></li>
            <li class="footer__menu-item"><a href="#" class="footer__menu-link">Terms of Service</a></li>
          {% endfor %}
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      &copy; {{ 'now' | date: "%Y" }} {{ shop.name | default: 'Sharddha Weaves' }}. All Rights Reserved.
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
