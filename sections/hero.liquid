<style>
.hero-slider {
  display: flex;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.hero-slider::-webkit-scrollbar {
  display: none;
}
.hero-slide {
  flex: 0 0 100%;
  width: 100%;
  scroll-snap-align: start;
  height: 80vh;
  position: relative;
  background-color: var(--color-warm-ivory);
}
.hero-slide__image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 1;
}
.hero-slide__overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.3); /* Slight darkening for text readability */
  z-index: 2;
}
.hero-slide__content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  z-index: 3;
  width: 90%;
  max-width: 800px;
  color: white; /* Forcing white text over images */
}
.hero-slide__subheading {
  font-family: var(--font-heading);
  font-size: clamp(1.2rem, 3vw, 2rem);
  font-style: italic;
  margin-bottom: 1rem;
}
.hero-slide__heading {
  font-family: var(--font-heading);
  font-size: clamp(2.5rem, 6vw, 4.5rem);
  line-height: 1.1;
  margin-bottom: 1.5rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}
.hero-slide__desc {
  font-size: 1.1rem;
  margin-bottom: 2rem;
  opacity: 0.9;
}
.hero-slide__btn {
  background-color: white;
  color: var(--color-dark-green);
}
.hero-slide__btn:hover {
  background-color: var(--color-muted-gold);
  color: white;
}
/* Dots navigation */
.hero-slider-nav {
  position: absolute;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 10px;
  z-index: 5;
}
.hero-slider-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background-color: rgba(255,255,255,0.5);
  cursor: pointer;
  border: 2px solid transparent;
}
.hero-slider-dot:hover {
  background-color: white;
}
</style>

<div style="position: relative;">
  <section class="hero-slider" id="heroSlider-{{ section.id }}">
    {% for block in section.blocks %}
      <div class="hero-slide" id="slide-{{ section.id }}-{{ forloop.index }}">
        {% if block.settings.image != blank %}
          {{ block.settings.image | image_url: width: 2000 | image_tag: class: 'hero-slide__image', alt: block.settings.heading }}
        {% else %}
          {% capture placeholder_index %}{% cycle 1, 2 %}{% endcapture %}
          {{ 'lifestyle-' | append: placeholder_index | placeholder_svg_tag: 'placeholder-svg hero-slide__image' }}
        {% endif %}
        
        <div class="hero-slide__overlay"></div>
        
        <div class="hero-slide__content">
          {% if block.settings.subheading != blank %}
            <h2 class="hero-slide__subheading">{{ block.settings.subheading }}</h2>
          {% endif %}
          {% if block.settings.heading != blank %}
            <h1 class="hero-slide__heading">{{ block.settings.heading }}</h1>
          {% endif %}
          {% if block.settings.description != blank %}
            <p class="hero-slide__desc">{{ block.settings.description }}</p>
          {% endif %}
          {% if block.settings.button_label != blank %}
            <a href="{{ block.settings.button_link | default: '#' }}" class="btn hero-slide__btn">{{ block.settings.button_label }}</a>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </section>
</div>

{% schema %}
{
  "name": "Hero Slider",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Latest Collection"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "ELEVATE YOUR STYLE"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Discover pieces crafted with precision and passion."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider",
      "blocks": [
        { "type": "slide" },
        { "type": "slide", "settings": { "heading": "TIMELESS ELEGANCE" } }
      ]
    }
  ]
}
{% endschema %}
