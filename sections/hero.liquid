<style>
.hero {
  height: 100vh;
  display: flex;
  background-color: var(--color-warm-ivory);
}
.hero-content {
  flex: 1;
  display: flex;
  align-items: center;
  padding-left: calc((100vw - var(--max-width)) / 2 + 2rem);
  padding-right: 4rem;
  z-index: 10;
}
.hero-text-wrapper {
  max-width: 600px;
}
.hero-heading {
  font-family: var(--font-heading);
  font-size: clamp(3.5rem, 6vw, 5.5rem);
  line-height: 1.1;
  margin-bottom: 2rem;
  color: var(--color-primary-text);
  letter-spacing: -0.01em;
}
.hero-subheading {
  font-family: var(--font-heading);
  font-size: clamp(1.8rem, 3vw, 2.5rem);
  font-weight: 400;
  font-style: italic;
  color: var(--color-dark-green);
  margin-bottom: 1rem;
}
.hero-desc {
  font-size: 1.1rem;
  color: var(--color-secondary-text);
  margin-bottom: 3rem;
  max-width: 450px;
  line-height: 1.8;
}
.hero-actions {
  display: flex;
  gap: 1.5rem;
}
.hero-image-wrapper {
  flex: 1;
  position: relative;
  overflow: hidden;
}
.hero-image-wrapper img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 30%;
}
</style>

<section class="hero">
  <div class="hero-content">
    <div class="hero-text-wrapper">
      {% if section.settings.subheading != blank %}
        <h2 class="hero-subheading">{{ section.settings.subheading }}</h2>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h1 class="hero-heading">{{ section.settings.heading }}</h1>
      {% endif %}
      {% if section.settings.description != blank %}
        <p class="hero-desc">{{ section.settings.description }}</p>
      {% endif %}
      <div class="hero-actions">
        {% if section.settings.button_1_label != blank %}
          <a href="{{ section.settings.button_1_link | default: '#' }}" class="btn btn-primary">{{ section.settings.button_1_label }}</a>
        {% endif %}
        {% if section.settings.button_2_label != blank %}
          <a href="{{ section.settings.button_2_link | default: '#' }}" class="btn btn-secondary">{{ section.settings.button_2_label }}</a>
        {% endif %}
      </div>
    </div>
  </div>
  <div class="hero-image-wrapper">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 2000 | image_tag: alt: section.settings.image.alt }}
    {% else %}
      <img src="{{ 'hero.png' | asset_url }}" alt="Hero Image Default">
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "THREAD OF TRADITION"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Rooted in Culture, Woven for Today"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover handcrafted kurtis and sarees designed for women who appreciate timeless elegance."
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Button 1 Label",
      "default": "Shop Collection"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button 1 Link"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Button 2 Label",
      "default": "Explore Lookbook"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button 2 Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}
