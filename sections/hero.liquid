<style>
.hero-slider {
  display: flex;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.hero-slider::-webkit-scrollbar {
  display: none;
}
.hero-slide {
  flex: 0 0 100%;
  width: 100%;
  scroll-snap-align: start;
  height: 85vh;
  position: relative;
  background-color: var(--color-warm-ivory);
}
.hero-slide__image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 1;
}
.hero-slide__overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(248, 244, 238, 0.2);
  z-index: 2;
}
.hero-slide__content-wrapper {
  position: relative;
  z-index: 3;
  width: 100%;
  height: 100%;
  max-width: var(--container-xl-max-width);
  margin: 0 auto;
  display: flex;
  align-items: center;
  padding: 0 2rem;
}
.hero-slide__content {
  text-align: center;
  max-width: 500px;
  color: #ffffff;
  margin-top: -2rem; /* visually balance vertical alignment */
}
.hero-slide__subheading {
  font-family: var(--font-body);
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 1.5rem;
  color: rgba(255, 255, 255, 0.9);
}
.hero-slide__heading {
  font-family: var(--font-heading);
  font-size: clamp(3rem, 6vw, 4.5rem);
  line-height: 1;
  margin-bottom: 0.5rem;
  color: #ffffff;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.hero-slide__heading-script {
  font-family: 'Great Vibes', 'Cormorant Garamond', cursive, serif; /* Fallback to a script/italic look */
  font-size: clamp(3.5rem, 7vw, 5rem);
  font-style: italic;
  text-transform: capitalize;
  display: block;
  margin-top: -0.5rem;
  color: #ffffff;
  font-weight: 400;
}
.hero-slide__divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 1.5rem 0;
  gap: 15px;
}
.hero-slide__divider::before,
.hero-slide__divider::after {
  content: "";
  height: 1px;
  background-color: #ffffff;
  flex: 0.2;
}
.hero-slide__divider-icon {
  width: 24px;
  height: 24px;
  fill: #ffffff;
}
.hero-slide__desc {
  font-family: var(--font-body);
  font-size: 0.9rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 2.5rem;
  font-weight: 600;
}
.hero-slide__btn {
  background-color: #ffffff;
  color: var(--color-dark-green);
  padding: 1rem 3rem;
  font-size: 0.9rem;
  letter-spacing: 0.1em;
  border-radius: 50px;
  display: inline-block;
  text-decoration: none;
  font-weight: 600;
  transition: all 0.3s ease;
}
.hero-slide__btn:hover {
  background-color: var(--color-soft-beige);
  color: var(--color-dark-green);
}

@media (max-width: 768px) {
  .hero-slide {
    height: 70vh;
  }
  .hero-slide__overlay {
    background: rgba(248, 244, 238, 0.2);
  }
  .hero-slide__content-wrapper {
    justify-content: center;
    padding: 0 1rem;
  }
  .hero-slide__content {
    margin-top: 0;
  }
}
</style>

<!-- Adding a script font to closely match the "Tradition" cursive text if it isn't loaded -->
<link href="https://fonts.googleapis.com/css2?family=Great+Vibes&display=swap" rel="stylesheet">

<div style="position: relative;">
  <section class="hero-slider" id="heroSlider-{{ section.id }}">
    {% for block in section.blocks %}
      <div class="hero-slide" id="slide-{{ section.id }}-{{ forloop.index }}">
        {% if block.settings.image != blank %}
          {{ block.settings.image | image_url: width: 2000 | image_tag: class: 'hero-slide__image', alt: block.settings.heading }}
        {% else %}
          {% if forloop.index == 1 %}
            <img src="https://images.unsplash.com/photo-1583391733958-d25e07fac66e?q=80&w=2000&auto=format&fit=crop" class="hero-slide__image" alt="Hero 1">
          {% else %}
            <img src="https://images.unsplash.com/photo-1610030469983-98e550d6193c?q=80&w=2000&auto=format&fit=crop" class="hero-slide__image" alt="Hero 2">
          {% endif %}
        {% endif %}
        
        <div class="hero-slide__overlay"></div>
        
        <div class="hero-slide__content-wrapper">
          <div class="hero-slide__content">
            {% if block.settings.subheading != blank %}
              <div class="hero-slide__subheading">{{ block.settings.subheading }}</div>
            {% endif %}
            
            {% if block.settings.heading != blank %}
              <h1 class="hero-slide__heading">
                {{ block.settings.heading }}
                {% if block.settings.heading_script != blank %}
                  <span class="hero-slide__heading-script">{{ block.settings.heading_script }}</span>
                {% endif %}
              </h1>
            {% endif %}

            <div class="hero-slide__divider">
              <svg class="hero-slide__divider-icon" viewBox="0 0 24 24"><path d="M12 2L15 8H9L12 2Z"/><path d="M12 22L9 16H15L12 22Z"/><path d="M2 12L8 9V15L2 12Z"/><path d="M22 12L16 15V9L22 12Z"/></svg>
            </div>
            
            {% if block.settings.description != blank %}
              <p class="hero-slide__desc">{{ block.settings.description }}</p>
            {% endif %}
            
            {% if block.settings.button_label != blank %}
              <a href="{{ block.settings.button_link | default: '#' }}" class="btn hero-slide__btn">{{ block.settings.button_label }}</a>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </section>
</div>

{% schema %}
{
  "name": "Hero Slider",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Rooted in culture, woven for today"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "SHARDDHA"
        },
        {
          "type": "text",
          "id": "heading_script",
          "label": "Heading Script Line",
          "default": "Weaves"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "KURTIS & SAREES COLLECTION"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "SHOP NOW"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider",
      "blocks": [
        { 
          "type": "slide", 
          "settings": { 
            "heading": "SHARDDHA",
            "heading_script": "Weaves"
          } 
        }
      ]
    }
  ]
}
{% endschema %}
