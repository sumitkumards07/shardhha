<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    <title>{{ page_title }} - {{ shop.name }}</title>
  <meta name="description" content="{{ page_description | escape }}">
  <link rel="canonical" href="{{ canonical_url }}">
  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400&family=Nunito:ital,wght@0,300;0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">

  {%- style -%}
    {{ settings.font_heading | font_face }}
    {{ settings.font_body | font_face }}
    
    :root {
      --color-warm-ivory: #ffffff; /* Override to clean white for editorial look */
      --color-soft-beige: #f9f9f9;
      --color-dark-green: #4d1010; /* Evara deep maroon */
      --color-muted-gold: #330a0a;
      --color-primary-text: #1c1c1c;
      --color-secondary-text: #666666;
      --color-border: #e4dbdb;
      
      --font-heading: 'Instrument Sans', sans-serif;
      --font-body: 'Nunito', sans-serif;
      
      --section-spacing: 4rem;
    }
    body {
      background-color: var(--color-warm-ivory);
      color: var(--color-primary-text);
      font-family: var(--font-body);
    }
  {%- endstyle -%}

  {{ 'theme.css' | asset_url | stylesheet_tag }}
  </head>

  <body>
    {% section 'header' %}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>
    
    {% section 'footer' %}
  </body>
</html>
